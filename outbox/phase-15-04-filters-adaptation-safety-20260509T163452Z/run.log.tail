+        validate_phase15_adaptation_safety_manifest(manifest)
+
+    manifest = _valid_manifest()
+    manifest["split_policy"]["test_split_manifest_sha256"] = manifest["split_policy"][
+        "calibration_split_manifest_sha256"
+    ]
+    with pytest.raises(
