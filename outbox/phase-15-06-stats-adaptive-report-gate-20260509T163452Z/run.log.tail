+@pytest.mark.fast
+def test_gated_claim_flags_pass_with_matching_audited_verdict_artifact() -> None:
+    payload = _payload_with_audit("Synthetic adaptive report.")
+    payload["claims"]["sota"] = True
+    payload["audited_verdict_artifact"]["authorized_claim_categories"] = ["sota"]
+
+    report = build_phase15_adaptive_report_gate(payload)
+
+    assert report["gate_status"] == "passed"
+    assert _gate(report, "claim_flag_gate")["matched_categories"] == ["sota"]
+    assert _gate(report, "authorization_gate")["authorized_categories"] == ["sota"]
+    assert report["blocking_gaps"] == []
+    _assert_strict_json(report)
+
+
+@pytest.mark.fast
+@pytest.mark.parametrize(
+    ("mutate", "expected_gap"),
+    [
+        (
+            lambda payload: payload["audited_verdict_artifact"].pop("phase15_evidence"),
+            "missing_phase15_evidence",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"].update(
+                {"artifact_sha256": "not-a-sha256"}
+            ),
+            "invalid_verdict_hash",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"]["metrics"].update(
+                {"audited_delta_gate_count": math.inf}
+            ),
+            "non_finite_verdict_metric",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"].update(
+                {"split_ids": ["synthetic-train-a"], "split_roles": {"synthetic-train-a": "train"}}
+            ),
+            "split_leakage",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"]["phase15_evidence"][
+                "adaptive_delta_gate_report"
+            ]["paired_delta_rows"][0]["adaptive_metrics"].update({"rmse": math.nan}),
+            "non_finite_delta_metric",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"]["phase15_evidence"][
+                "adaptive_delta_gate_report"
+            ].update({"blocking_gaps": [{"gap_id": "split_leakage"}]}),
+            "adaptive_delta_gate_has_blocking_gaps",
+        ),
+    ],
+)
+def test_invalid_audited_verdict_evidence_fails_closed(
+    mutate: Callable[[dict[str, Any]], object],
+    expected_gap: str,
+) -> None:
+    payload = _payload_with_audit("The adaptive method is superior to the baseline.")
+    mutate(payload)
+
+    report = build_phase15_adaptive_report_gate(payload)
+
+    assert report["gate_status"] == "blocked"
+    assert _gate(report, "authorization_gate")["status"] == "blocked"
+    assert expected_gap in _gap_ids(report)
+    assert "unauthorized_claim_wording" in _gap_ids(report)
+    _assert_strict_json(report)
+
+
