+
+
+def _loader_for_parquet(
+    tmp_path: Path,
+    *,
+    profile: str = "DST",
+    temp_c: int = 25,
+    cell_idx: int = 0,
+    **parquet_kwargs: object,
+) -> CalceA123DynLoader:
+    parquet_path = tmp_path / _parquet_filename(profile, temp_c, cell_idx)
+    _write_synthetic_parquet(parquet_path, **parquet_kwargs)
+    return CalceA123DynLoader(local_cache_root=tmp_path)
+
+
+def test_constants() -> None:
+    assert CALCE_A123_DYN_HF_REPO == "bsebench-org/calce-a123-2014-dynamic"
+    assert CALCE_SOURCE_URL == "https://calce.umd.edu/battery-data"
+    assert CALCE_A123_DYN_PROFILES == ("DST", "US06", "FUDS")
+    assert CALCE_A123_DYN_TEMPS_C == (-10, 0, 10, 20, 25, 30, 40, 50)
+    assert DATASET_TAG == "calce_a123_lfp"
+    assert CHEMISTRY_TAG == "LFP_A123_APR18650M1A"
+
+
+def test_loader_constructor_and_wrapper_name() -> None:
+    loader = CalceA123DynLoader(downloader=lambda _: "/nonexistent")
+    assert loader.wrapper_name == "calce_a123_dyn"
+
+
+def test_loader_rejects_downloader_and_local_cache_root(tmp_path: Path) -> None:
+    with pytest.raises(ValueError, match="Pass either downloader or local_cache_root"):
+        CalceA123DynLoader(downloader=lambda _: "/nonexistent", local_cache_root=tmp_path)
+
+
+def test_loader_available_configs() -> None:
+    expected = [
+        (profile, float(temp_c))
+        for profile in ("DST", "US06", "FUDS")
+        for temp_c in (-10, 0, 10, 20, 25, 30, 40, 50)
+    ]
+    assert CalceA123DynLoader().available_configs() == expected
+    assert len(expected) == 24
+
+
+def test_loader_rejects_invalid_profile() -> None:
+    loader = CalceA123DynLoader(downloader=lambda _: "/nonexistent")
+    with pytest.raises(AdapterNotAvailableError, match="profile 'BJDST'"):
+        loader.load("BJDST", 25.0)
+
+
+def test_loader_rejects_invalid_temperature() -> None:
+    loader = CalceA123DynLoader(downloader=lambda _: "/nonexistent")
+    with pytest.raises(AdapterNotAvailableError, match=r"T_C=45\.0"):
+        loader.load("DST", 45.0)
+
+
+def test_loader_rejects_non_integer_temperature_label() -> None:
+    loader = CalceA123DynLoader(downloader=lambda _: "/nonexistent")
+    with pytest.raises(AdapterNotAvailableError, match=r"T_C=25\.5"):
+        loader.load("DST", 25.5)
+
+
+def test_loader_rejects_invalid_cell_idx() -> None:
+    loader = CalceA123DynLoader(downloader=lambda _: "/nonexistent")
+    with pytest.raises(AdapterNotAvailableError, match="cell_idx must be 0 or 1"):
+        loader.load("DST", 25.0, cell_idx=2)
+
+
+@pytest.mark.parametrize(
+    ("profile", "temp_c", "cell_idx", "expected_cell_id"),
+    [
+        ("DST", -10, 0, "A123_DST_T-10_cell0"),
+        ("US06", 50, 0, "A123_US06_T50_cell0"),
+        ("FUDS", -10, 1, "A123_FUDS_T-10_cell1"),
+    ],
+)
+def test_loader_cell_id_format_for_profiles_and_extreme_temps(
+    tmp_path: Path,
+    profile: str,
+    temp_c: int,
+    cell_idx: int,
+    expected_cell_id: str,
+) -> None:
+    loader = _loader_for_parquet(tmp_path, profile=profile, temp_c=temp_c, cell_idx=cell_idx)
+    out = loader.load(profile, float(temp_c), cell_idx=cell_idx)
+    assert out["cell_id"] == expected_cell_id
+
+
+def test_loader_flips_bpx_current_to_discharge_positive(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, current_a=-3.0)
+    out = loader.load("DST", 25.0)
+    assert np.allclose(out["I"], 3.0)
+
+
+def test_loader_rebases_time_to_zero(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, time_start_s=100.0)
+    out = loader.load("DST", 25.0)
+    assert out["t"][0] == 0.0
+    assert np.allclose(out["t"][:3], [0.0, 1.0, 2.0])
+
+
+def test_loader_schema_keys(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path)
+    out = loader.load("DST", 25.0)
+    assert set(out) == {
+        "t",
+        "V",
+        "I",
+        "T_meas",
+        "N",
+        "T_amb",
+        "cell_id",
+        "dataset",
+        "chemistry",
+        "source_url",
+    }
+
+
+def test_loader_length_consistency(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, n_samples=17)
+    out = loader.load("DST", 25.0)
+    n = out["N"]
+    assert len(out["t"]) == len(out["V"]) == len(out["I"]) == len(out["T_meas"]) == n
+
+
+def test_loader_metadata_values(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path)
+    out = loader.load("DST", 25.0)
+    assert out["T_amb"] == 25.0
+    assert out["dataset"] == "calce_a123_lfp"
+    assert out["chemistry"] == "LFP_A123_APR18650M1A"
+    assert out["source_url"] == "https://calce.umd.edu/battery-data"
+
+
+def test_loader_cell_idx_zero_vs_one(tmp_path: Path) -> None:
+    _write_synthetic_parquet(tmp_path / _parquet_filename("US06", 20, 0), current_a=-1.0)
+    _write_synthetic_parquet(tmp_path / _parquet_filename("US06", 20, 1), current_a=-2.0)
+    loader = CalceA123DynLoader(local_cache_root=tmp_path)
+
+    out0 = loader.load("US06", 20.0, cell_idx=0)
+    out1 = loader.load("US06", 20.0, cell_idx=1)
+
+    assert out0["cell_id"] == "A123_US06_T20_cell0"
+    assert out1["cell_id"] == "A123_US06_T20_cell1"
+    assert np.allclose(out0["I"], 1.0)
+    assert np.allclose(out1["I"], 2.0)
+
+
+def test_loader_downloader_receives_expected_filename(tmp_path: Path) -> None:
+    parquet_path = tmp_path / _parquet_filename("FUDS", 50, 1)
+    _write_synthetic_parquet(parquet_path)
+    calls: list[str] = []
+
+    def downloader(filename: str) -> str:
+        calls.append(filename)
+        return str(parquet_path)
+
+    loader = CalceA123DynLoader(downloader=downloader)
+    out = loader.load("FUDS", 50.0, cell_idx=1)
+    assert calls == ["calce_a123_dyn_FUDS_T50_cell1.parquet"]
+    assert out["cell_id"] == "A123_FUDS_T50_cell1"
+
+
+@pytest.mark.slow
+def test_loader_calce_a123_dyn_dst_t25_cell0_paper2b_compat(tmp_path: Path) -> None:
+    raw_root = CALCE_LOCAL_DYN_RAW_ROOT
+    raw_zip = raw_root / DYN_T_TO_ZIP[25]
+    if not raw_zip.is_file():
+        pytest.skip(f"local CALCE A123 dynamic zip not found at {raw_zip}")
+
+    pytest.importorskip("pandas")
+    pytest.importorskip("openpyxl")
+
+    written = CalceA123Adapter(local_root=raw_root).harmonize(output_dir=tmp_path)
+    assert "A123_DST_T25_cell0" in written
+
+    loader = CalceA123DynLoader(local_cache_root=tmp_path)
+    out = loader.load("DST", 25.0, cell_idx=0)
+    assert out["cell_id"] == "A123_DST_T25_cell0"
+    assert out["chemistry"] == "LFP_A123_APR18650M1A"
+    assert out["N"] > 1000
+    assert out["t"][0] == 0.0

