+
+    missing = [column for column in REQUIRED_COLUMNS if column not in df.columns]
+    if missing:
+        raise ValueError(f"{xls_path.name} is missing required columns: {missing}")
+
+    time_s = df["Test_Time(s)"].to_numpy(dtype=np.float64)
+    voltage_v = df["Voltage(V)"].to_numpy(dtype=np.float64)
+    current_a = df["Current(A)"].to_numpy(dtype=np.float64)
+    temperature_c = np.full(len(df), float(temp_c), dtype=np.float64)
+
+    return pa.table(
+        {
+            "time_s": pa.array(time_s - time_s[0], type=pa.float64()),
+            "voltage_V": pa.array(voltage_v, type=pa.float64()),
+            "current_A": pa.array(current_a, type=pa.float64()),
+            "temperature_C": pa.array(temperature_c, type=pa.float64()),
+        }
+    )
+
+
+def harmonize(local_root: Path, output_dir: Path) -> dict[str, Path]:
+    """Convert caller-supplied CALCE INR-20R zip bundles to canonical Parquet."""
+    return CalceInr20RAdapter(local_root=local_root).harmonize(output_dir)
+
+
+__all__ = [
+    "CHEMISTRY_TAG",
+    "DATASET_TAG",
+    "MIN_SEGMENT_ROWS",
+    "NOMINAL_CAPACITY_AH",
+    "PROFILES",
+    "REQUIRED_COLUMNS",
+    "SOC_STARTS",
+    "TEMPS_C",
+    "T_TO_ZIP_PATTERN",
+    "CalceInr20RAdapter",
+    "harmonize",
+]
