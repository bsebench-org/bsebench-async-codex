+## Roadmap
+
+The active research roadmap lives in [`bsebench-async-codex/docs/RESEARCH-ROADMAP-2026-05-06.md`](https://github.com/bsebench-org/bsebench-async-codex/blob/main/docs/RESEARCH-ROADMAP-2026-05-06.md). Near-term dataset work focuses on landing CALCE INR-20R Tier 2 support, expanding aging coverage, and keeping every public benchmark claim traceable to a loader, manifest, and immutable data artifact.
diff --git a/examples/01_load_nasa_pcoe_2007.py b/examples/01_load_nasa_pcoe_2007.py
new file mode 100755
index 0000000000000000000000000000000000000000..99c5efd4a32af4825bf97ce5c49bc75aadf571d6
--- /dev/null
+++ b/examples/01_load_nasa_pcoe_2007.py
@@ -0,0 +1,27 @@
+from __future__ import annotations
+
+import numpy as np
+
+from bsebench_datasets.loaders.nasa_pcoe_loader import NasaPcoeLoader
+
+
+def _stats(values: np.ndarray) -> str:
+    return (
+        f"min={np.nanmin(values):.3f}, mean={np.nanmean(values):.3f}, max={np.nanmax(values):.3f}"
+    )
+
+
+def main() -> None:
+    trace = NasaPcoeLoader().load("CC-discharge", 24.0)
+    time_s = trace["t"]
+    voltage_v = trace["V"]
+    current_a = trace["I"]
+
+    print(f"dataset=NASA PCoE 2007 cell_id={trace['cell_id']} samples={trace['N']}")
+    print(f"t shape={time_s.shape}, {_stats(time_s)} s")
+    print(f"V shape={voltage_v.shape}, {_stats(voltage_v)} V")
+    print(f"I shape={current_a.shape}, {_stats(current_a)} A discharge-positive")
+
+
+if __name__ == "__main__":
+    main()
