+    assert _gate(report, "authorization_gate")["horizon_steps"] == 1
+    assert report["blocking_gaps"] == []
+    _assert_strict_json(report)
+
+
+@pytest.mark.fast
+def test_gated_claim_flags_require_audited_verdict_artifact() -> None:
+    payload = _payload()
+    payload["claims"]["sota"] = True
+
+    report = build_phase14_bound_report_gate(payload)
+
+    assert report["gate_status"] == "blocked"
+    assert _gate(report, "claim_flag_gate")["matched_categories"] == ["sota"]
+    assert "missing_audited_verdict_artifact" in _gap_ids(report)
+    assert "unauthorized_claim_flag" in _gap_ids(report)
+    _assert_strict_json(report)
+
+
+@pytest.mark.fast
+@pytest.mark.parametrize(
+    ("mutate", "expected_gap"),
+    [
+        (
+            lambda payload: payload["audited_verdict_artifact"].pop("phase14_evidence"),
+            "missing_phase14_evidence",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"]["metrics"].update(
+                {"mechanical_evidence_count": math.inf}
+            ),
+            "non_finite_verdict_metric",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"]["phase14_evidence"][
+                "linear_pcrlb_report"
+            ]["dimensions"].update({"state_dim": 3}),
+            "dimension_mismatch",
+        ),
+        (
+            lambda payload: payload["audited_verdict_artifact"]["phase14_evidence"][
+                "linear_pcrlb_report"
+            ]["covariance_lower_bound_sequence"][1][1].__setitem__(1, -0.1),
+            "invalid_covariance_matrix",
+        ),
+    ],
+)
+def test_invalid_audited_verdict_evidence_fails_closed(
+    mutate: Callable[[dict[str, Any]], object],
+    expected_gap: str,
+) -> None:
+    payload = _payload_with_claim("The report uses empirical bound wording.")
+    mutate(payload)
+
+    report = build_phase14_bound_report_gate(payload)
+
+    assert report["gate_status"] == "blocked"
+    assert _gate(report, "authorization_gate")["status"] == "blocked"
+    assert expected_gap in _gap_ids(report)
+    assert "unauthorized_claim_wording" in _gap_ids(report)
+    _assert_strict_json(report)
+
+
+@pytest.mark.fast
+def test_verdict_artifact_must_authorize_matched_claim_category() -> None:
+    payload = _payload_with_claim("The report uses a tight bound phrase.")
+    payload["audited_verdict_artifact"]["authorized_claim_categories"] = ["leaderboard"]
+
+    report = build_phase14_bound_report_gate(payload)
+
+    assert report["gate_status"] == "blocked"
+    assert "unauthorized_claim_category" in _gap_ids(report)
+    assert "unauthorized_claim_wording" in _gap_ids(report)
+
+
+@pytest.mark.fast
+def test_payload_is_not_mutated() -> None:
+    payload = _payload_with_claim("The audited report uses leaderboard wording.")
+    before = copy.deepcopy(payload)
+
+    build_phase14_bound_report_gate(payload)
+
+    assert payload == before
+
+
+@pytest.mark.fast
+def test_file_runner_writes_finite_json_report(tmp_path: Path) -> None:
+    input_path = tmp_path / "phase14_bound_gate_input.json"
+    output_path = tmp_path / "phase14_bound_gate_report.json"
+    input_path.write_text(json.dumps(_payload(), allow_nan=False), encoding="utf-8")
+
+    report = run_phase14_bound_report_gate(input_path, output_path)
+
+    assert output_path.exists()
+    loaded = json.loads(output_path.read_text(encoding="utf-8"))
+    assert loaded == report
+    assert loaded["source"] == {"input_path": str(input_path)}
+
+
+@pytest.mark.fast
+def test_unprocessable_top_level_payload_fails_loud() -> None:
+    with pytest.raises(Phase14BoundReportGateError, match="gate_payload must be an object"):
+        build_phase14_bound_report_gate(["not", "an", "object"])

