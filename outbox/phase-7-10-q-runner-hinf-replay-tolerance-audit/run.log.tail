+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _copy_bundle(
+    tmp_path: Path,
+    *,
+    manifest_payload: dict[str, Any] | None = None,
+    evidence_payload: dict[str, Any] | None = None,
+) -> dict[str, Path]:
+    outputs = tmp_path / "outputs"
+    outputs.mkdir()
+    paths = {
+        "manifest": outputs / "hinf_residual_artifact_manifest.json",
+        "preflight": outputs / "hinf_residual_cache_preflight.json",
+        "chi2": outputs / "chi2_sweep_5x5.json",
+        "evidence": outputs / "hinf_residual_evidence_5x5.json",
+        "uv_lock": tmp_path / "uv.lock",
+    }
+    shutil.copy2(PREFLIGHT_PATH, paths["preflight"])
+    shutil.copy2(CHI2_PATH, paths["chi2"])
+    shutil.copy2(REPO_ROOT / "uv.lock", paths["uv_lock"])
+    if evidence_payload is None:
+        shutil.copy2(EVIDENCE_PATH, paths["evidence"])
+    else:
+        _write_json(paths["evidence"], evidence_payload)
+
+    manifest = copy.deepcopy(manifest_payload or _json(MANIFEST_PATH))
+    for role in ("preflight", "chi2", "evidence", "uv_lock"):
+        artifact_path = paths[role]
+        manifest["artifacts"][role]["path"] = artifact_path.relative_to(tmp_path).as_posix()
+        manifest["artifacts"][role]["sha256"] = _sha256(artifact_path)
+        manifest["artifacts"][role]["size_bytes"] = artifact_path.stat().st_size
+    _write_json(paths["manifest"], manifest)
+    return paths
+
+
