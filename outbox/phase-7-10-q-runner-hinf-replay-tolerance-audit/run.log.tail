+@pytest.mark.fast
+def test_audit_rejects_manifest_artifact_hash_drift(audit_module, tmp_path: Path) -> None:
+    manifest = copy.deepcopy(_json(MANIFEST_PATH))
+    paths = _copy_bundle(tmp_path, manifest_payload=manifest)
+    bad_manifest = _json(paths["manifest"])
+    bad_manifest["artifacts"]["evidence"]["sha256"] = "0" * 64
+    _write_json(paths["manifest"], bad_manifest)
+
+    with pytest.raises(
+        audit_module.HinfReplayToleranceAuditError,
+        match=r"manifest\.artifacts\.evidence\.sha256",
+    ):
+        audit_module.audit_hinf_replay_tolerance(
+            manifest_path=paths["manifest"],
+            preflight_path=paths["preflight"],
+            chi2_path=paths["chi2"],
+            evidence_path=paths["evidence"],
+            repo_root=tmp_path,
+        )
+
+
