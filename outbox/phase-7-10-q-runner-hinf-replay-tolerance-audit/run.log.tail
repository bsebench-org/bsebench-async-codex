+    )
+    assert report["replay"]["tolerances"] == {"atol": 1.0e-12, "rtol": 1.0e-12}
+    assert report["replay"]["tolerance_contract"] == {"atol": 1.0e-12, "rtol": 1.0e-12}
+    assert report["replay"]["mismatch_count"] == 0
+    assert report["replay"]["max_absolute_delta"] >= 0.0
+    assert report["replay"]["max_relative_delta"] >= 0.0
+    assert report["stats_dependency"]["manifest"]["locked_git_sha"] == EXPECTED_STATS_SHA
+    assert report["stats_dependency"]["runtime_import"]["direct_url_commit_id"] == (
+        EXPECTED_STATS_SHA
+    )
+    assert report["stats_dependency"]["stale_dependency_status"] == "not_stale"
+
