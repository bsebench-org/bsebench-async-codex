+    parser.add_argument("--repo-root", default=str(REPO_ROOT))
+    parser.add_argument("--max-mismatches", type=int, default=20)
+    return parser.parse_args(argv)
+
+
+def format_summary(summary: Mapping[str, object]) -> str:
+    """Return compact command-line output for CI logs."""
+    outputs = _mapping(summary.get("outputs"), "summary.outputs")
+    evidence = _mapping(outputs.get("evidence"), "summary.outputs.evidence")
+    identity = _mapping(summary.get("identity"), "summary.identity")
+    sidecar = _mapping(summary.get("sidecar"), "summary.sidecar")
+    return "\n".join(
+        [
+            "hinf residual CI summary audit ok",
+            (
+                "manifest links: "
+                f"{_mapping(summary.get('manifest'), 'summary.manifest')['artifacts']} "
+                "artifacts sha256 ok"
+            ),
+            (
+                "committed outputs: "
+                f"ok_configs={evidence['ok_configs']} "
+                f"ok_filter_runs={evidence['ok_filter_runs']}"
+            ),
+            (
+                "strict identity: "
+                f"configs={len(_string_sequence(identity['config_labels'], 'identity.configs'))} "
+                f"filters={len(_string_sequence(identity['filter_labels'], 'identity.filters'))}"
+            ),
+            (
+                "sensitivity sidecar: "
+                f"{sidecar['material_sensitivity_status']} risks={sidecar['risk_count']}"
+            ),
+        ]
+    )
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = parse_args(argv)
+    try:
+        summary = audit_ci_summary(
+            manifest_path=args.manifest,
+            preflight_path=args.preflight,
+            chi2_path=args.chi2,
+            evidence_path=args.evidence,
+            candidate_summary_path=args.candidate_summary,
+            candidate_markdown_path=args.candidate_markdown,
+            sidecar_path=args.sidecar,
+            repo_root=args.repo_root,
+            max_mismatches=args.max_mismatches,
+        )
+    except (
+        HinfResidualCISummaryAuditError,
+        HinfResidualManifestAuditError,
+        HinfResidualOutputAuditError,
+        HinfResidualSensitivitySidecarAuditError,
+        HinfCandidateReportError,
+    ) as exc:
+        print(f"hinf residual CI summary audit failed: {exc}", file=sys.stderr)
+        return 2
+    print(format_summary(summary))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
