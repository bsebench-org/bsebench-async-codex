+                "sha256": "e" * 64,
+                "process_covariance": [[0.01, 0.0], [0.0, 0.02]],
+                "measurement_covariance": [[0.03]],
+                "prior_information": [[10.0, 0.0], [0.0, 5.0]],
+            },
+        },
+    }
+
+
+def test_phase14_bound_plan_ready_for_synthetic_metadata_without_execution() -> None:
+    plan = build_phase14_bound_plan(
+        _inputs(),
+        generated_at="2026-05-09T14:57:52Z",
+    )
+
+    assert plan["schema_version"] == PHASE14_BOUND_PLAN_SCHEMA_VERSION
+    assert plan["scientific_verdict"] == NO_GO_CLAIM
+    assert plan["dry_run_only"] is True
+    assert plan["mechanical_validation_only"] is True
+    assert plan["theory_preflight_only"] is True
+    assert plan["decision"]["plan_status"] == "ready"
+    assert plan["decision"]["information_bound_plan_ready"] is True
+    assert plan["decision"]["bound_computation_allowed"] is False
+    assert plan["decision"]["estimator_execution_allowed"] is False
+    assert plan["decision"]["filter_execution_allowed"] is False
+    assert plan["decision"]["dataset_download_allowed"] is False
+    assert plan["decision"]["hf_upload_allowed"] is False
+    assert plan["decision"]["soc_derivation_allowed"] is False
+    assert plan["decision"]["soh_derivation_allowed"] is False
+    assert plan["decision"]["parameter_fitting_allowed"] is False
+    assert plan["decision"]["parameter_use_allowed"] is False
+    assert plan["execution"] == {
+        "attempted": False,
+        "dataset_download_attempted": False,
+        "hf_upload_attempted": False,
+        "filter_execution_attempted": False,
+        "estimator_execution_attempted": False,
+        "bound_computation_attempted": False,
+        "soc_derivation_attempted": False,
+        "soh_derivation_attempted": False,
+        "reason": "phase14_information_bound_plan_dry_run_only",
+    }
+    assert plan["blocking_gaps"] == []
+    assert all(status["ready"] is True for status in plan["component_status"].values())
+    json.dumps(plan, allow_nan=False)
+
+
+def test_phase14_bound_plan_blocks_missing_required_evidence() -> None:
+    payload = _inputs()
+    payload["evidence"].pop("truth")
+    payload["evidence"]["split"].pop("sha256")
+    payload["evidence"]["linearization"].pop("method")
+
+    plan = build_phase14_bound_plan(payload)
+
+    assert plan["decision"]["plan_status"] == "blocked"
+    assert plan["decision"]["information_bound_plan_ready"] is False
+    assert plan["decision"]["estimator_execution_allowed"] is False
+    assert "missing_truth_evidence" in plan["blocking_gaps"]
+    assert "missing_truth_sha256" in plan["blocking_gaps"]
+    assert "missing_split_sha256" in plan["blocking_gaps"]
+    assert "missing_linearization_method" in plan["blocking_gaps"]
+    assert plan["component_status"]["truth"]["ready"] is False
+
+
+def test_phase14_bound_plan_blocks_non_finite_values_and_dimension_mismatches() -> None:
+    payload = _inputs()
+    payload["evidence"]["parameters"]["values"] = [2.8, math.inf]
+    payload["evidence"]["linearization"]["observation_jacobian"] = [[0.04, -0.2, 0.1]]
+    payload["evidence"]["linearization"]["parameter_vector"] = [2.8]
+
+    plan = build_phase14_bound_plan(payload)
+
+    assert plan["decision"]["plan_status"] == "blocked"
+    assert "non_finite:parameters.values[1]" in plan["blocking_gaps"]
+    assert (
+        "dimension_mismatch:linearization.observation_jacobian[0].columns expected=2 actual=3"
+    ) in plan["blocking_gaps"]
+    assert (
+        "dimension_mismatch:linearization.parameter_vector expected=2 actual=1"
+        in plan["blocking_gaps"]
+    )
+    assert plan["component_status"]["parameters"]["values"] == [2.8, None]
+    json.dumps(plan, allow_nan=False)
+
+
+def test_phase14_bound_plan_blocks_invalid_covariance_and_information_matrices() -> None:
+    payload = _inputs()
+    payload["evidence"]["noise"]["process_covariance"] = [[0.01, 0.02], [0.0, 0.02]]
+    payload["evidence"]["noise"]["measurement_covariance"] = [[-0.03]]
+    payload["evidence"]["noise"]["prior_information"] = [[1.0, 0.0], [0.0, 0.0]]
+
+    plan = build_phase14_bound_plan(payload)
+
+    assert plan["decision"]["plan_status"] == "blocked"
+    assert "matrix_not_symmetric:noise.process_covariance" in plan["blocking_gaps"]
+    assert "matrix_not_positive_definite:noise.measurement_covariance" in plan["blocking_gaps"]
+    assert "matrix_not_positive_definite:noise.prior_information" in plan["blocking_gaps"]
+    assert plan["decision"]["bound_computation_allowed"] is False
+
+
+def test_phase14_bound_plan_blocks_unsupported_claims() -> None:
+    payload = _inputs()
+    payload["requested_claims"] = ["information_bound_preflight_plan", "sota"]
+    payload["claims"]["filter_superiority"] = True
+
+    plan = build_phase14_bound_plan(payload)
+
+    assert plan["decision"]["plan_status"] == "blocked"
+    assert "unsupported_claim:sota" in plan["blocking_gaps"]
+    assert "unsupported_claim:filter_superiority" in plan["blocking_gaps"]
+    assert plan["scientific_verdict"] == NO_GO_CLAIM
+
+
+def test_phase14_bound_plan_rejects_invalid_input_collection() -> None:
+    with pytest.raises(Phase14BoundPlanError, match="inputs must be a mapping"):
+        build_phase14_bound_plan(["not", "a", "mapping"])  # type: ignore[arg-type]
+
+    with pytest.raises(Phase14BoundPlanError, match="generated_at must be a non-empty string"):
+        build_phase14_bound_plan(_inputs(), generated_at=" ")
+
+
+def test_phase14_bound_plan_load_write_and_hash_are_deterministic(tmp_path: Path) -> None:
+    inputs_path = tmp_path / "inputs.json"
+    inputs_path.write_text(json.dumps(_inputs(), indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    inputs = load_phase14_bound_inputs_json(inputs_path)
+    plan = build_phase14_bound_plan(inputs)
+    output_path = write_phase14_bound_plan_json(plan, tmp_path / "plan.json")
+    loaded = json.loads(output_path.read_text(encoding="utf-8"))
+
+    assert loaded == plan
+    assert len(phase14_bound_plan_sha256(plan)) == 64
+    assert phase14_bound_plan_sha256(plan) == phase14_bound_plan_sha256(loaded)
+
+
+def test_phase14_bound_plan_loader_rejects_non_standard_json_constants(tmp_path: Path) -> None:
+    inputs_path = tmp_path / "bad-inputs.json"
+    payload = _inputs()
+    payload["evidence"]["parameters"]["values"][0] = math.nan
+    inputs_path.write_text(json.dumps(payload, allow_nan=True), encoding="utf-8")
+
+    with pytest.raises(Phase14BoundPlanError, match="non-standard JSON constant"):
+        load_phase14_bound_inputs_json(inputs_path)

