+def test_build_manifest_sorts_inputs_and_summarizes_compute_fields() -> None:
+    manifest = build_phase13_compute_profile_manifest(**_manifest_kwargs())
+
+    assert manifest["schema_version"] == PHASE13_COMPUTE_PROFILE_SCHEMA_VERSION
+    assert manifest["manifest_id"].startswith(PHASE13_COMPUTE_PROFILE_ID_PREFIX)
+    assert [split["split_id"] for split in manifest["splits"]] == [
+        "validation-a",
+        "validation-b",
+    ]
+    assert [member["member_id"] for member in manifest["members"]] == ["member-a", "member-b"]
+    assert manifest["units"] == {
+        "runtime_ns": "nanoseconds",
+        "memory_current_bytes": "bytes_caller_reported_current",
+        "memory_peak_bytes": "bytes_caller_reported_peak",
+        "iteration_count": "iterations",
+    }
+    assert manifest["summary"] == {
+        "member_count": 2,
+        "split_count": 2,
+        "runtime_ns_total": 200,
+        "runtime_ns_max": 125,
+        "memory_current_bytes_max": 11,
+        "memory_peak_bytes_max": 30,
+        "iteration_count_total": 8,
+        "complete": True,
+    }
+    assert validate_phase13_compute_profile_manifest(manifest) == manifest["summary"]
+    json.dumps(manifest, allow_nan=False)
+
+
+@pytest.mark.fast
+def test_manifest_id_is_stable_for_input_order() -> None:
+    left = build_phase13_compute_profile_manifest(**_manifest_kwargs())
+    kwargs = _manifest_kwargs()
+    kwargs["splits"] = list(reversed(kwargs["splits"]))  # type: ignore[arg-type]
+    kwargs["member_profiles"] = list(reversed(kwargs["member_profiles"]))  # type: ignore[arg-type]
+
+    right = build_phase13_compute_profile_manifest(**kwargs)
+
+    assert left["manifest_id"] == right["manifest_id"]
+    assert left == right
+
+
+@pytest.mark.fast
+def test_write_manifest_validates_and_emits_strict_json(tmp_path) -> None:
+    manifest = build_phase13_compute_profile_manifest(**_manifest_kwargs())
+    output_path = write_phase13_compute_profile_manifest(
+        manifest,
+        tmp_path / "phase13-compute-profile.json",
+    )
+
+    loaded = json.loads(output_path.read_text(encoding="utf-8"))
+
+    assert loaded == manifest
+    assert output_path.read_text(encoding="utf-8").endswith("\n")
+
