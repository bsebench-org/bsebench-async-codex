+    assert estimate.value == pytest.approx(0.55)
+    assert estimate.state == {"soc": pytest.approx(0.55)}
+    assert estimate.auxiliary_predictions == {"voltage_predicted_V": pytest.approx(3.55)}
+    assert estimate.innovation == pytest.approx(0.01)
+    assert estimate.target == "soc"
+    assert estimate.evidence == sample_evidence()
+    assert estimate.provenance.estimator_name == "phase13-static-weighted-fixture"
+    assert evidence["schema_version"] == PHASE13_STATIC_WEIGHTED_ENSEMBLE_SCHEMA_VERSION
+    assert evidence["aggregation"]["strategy"] == PHASE13_STATIC_WEIGHTED_ENSEMBLE_STRATEGY
+    assert evidence["aggregation"]["weights"] == {"ekf": 0.25, "ukf": 0.75}
+    assert evidence["members"][0]["member_id"] == "ekf"
+    assert evidence["members"][0]["artifact_sha256"] == "b" * 64
+
+
+@pytest.mark.parametrize(
+    ("weights", "message"),
+    [
+        ({"ekf": 1.0}, "at least 2"),
+        ({"ekf": 0.5, "ukf": 0.4}, "sum to 1.0"),
+        ({"ekf": 1.0, "ukf": 0.0}, r"weights\.ukf must be positive"),
+        ({"ekf": 1.1, "ukf": -0.1}, r"weights\.ukf must be positive"),
+        ({"ekf": float("nan"), "ukf": 1.0}, r"weights\.ekf must be finite"),
+        ({"ekf": True, "ukf": 0.5}, r"weights\.ekf must be finite"),
+    ],
+)
+def test_weight_validation_fails_closed(weights: dict[str, float], message: str) -> None:
+    with pytest.raises(ContractComplianceError, match=message):
+        StaticWeightedEnsembleAdapter(method_id="bad-weights", weights=weights)
+
+
+@pytest.mark.parametrize(
+    ("mutate", "message"),
+    [
+        (
+            lambda members: members.pop(),
+            "must contain at least 2",
+        ),
+        (
+            lambda members: members.append(member("extra", 0.5)),
+            "must match weights exactly",
+        ),
+        (
+            lambda members: members.__setitem__(1, member("ukf", 0.6, split_id="other-split")),
+            r"ukf\.split_id mismatch",
+        ),
+        (
+            lambda members: members.__setitem__(
+                1,
+                member("ukf", 0.6, dataset_fingerprint=f"sha256:{'c' * 64}"),
+            ),
+            r"ukf\.dataset_fingerprint mismatch",
+        ),
+        (
+            lambda members: members.__setitem__(
+                1,
+                member("ukf", 0.6, evidence=sample_evidence("sample-002")),
+            ),
+            r"ukf\.sample_id mismatch",
+        ),
+        (
+            lambda members: members.__setitem__(1, member("ukf", 0.6, target="soh")),
+            r"ukf\.target mismatch",
+        ),
+        (
+            lambda members: members.__setitem__(1, member("ukf", 0.6, innovation=None)),
+            "innovations must be all present or all absent",
+        ),
+    ],
+)
+def test_member_evidence_and_contract_mismatches_fail_closed(
+    mutate: Callable[[list[StaticWeightedMemberEstimate]], None],
+    message: str,
+) -> None:
+    adapter = StaticWeightedEnsembleAdapter(
+        method_id="phase13-static-weighted-fixture",
+        weights={"ekf": 0.5, "ukf": 0.5},
+    )
+    members = [member("ekf", 0.4), member("ukf", 0.6)]
+    mutate(members)
+
+    with pytest.raises(ContractComplianceError, match=message):
+        adapter.combine(members)
+
+
+@pytest.mark.parametrize(
+    ("kwargs", "message"),
+    [
+        ({"split_id": "unknown"}, r"split_id must identify concrete provenance/evidence"),
+        ({"artifact_sha256": "not-a-sha"}, "artifact_sha256 must be a lowercase SHA-256"),
+        (
+            {"dataset_fingerprint": "not-a-fingerprint"},
+            "dataset_fingerprint must include a lowercase SHA-256",
+        ),
+    ],
+)
+def test_member_metadata_requires_split_hash_and_provenance(
+    kwargs: dict[str, str],
+    message: str,
+) -> None:
+    base = {
+        "member_id": "ekf",
+        "estimate": universal_estimate(name="ekf", value=0.4),
+        "run_id": "run-ekf",
+        "split_id": "calce-a123-train-freeze-v1",
+        "dataset_fingerprint": DATASET_FINGERPRINT,
+        "artifact_sha256": "b" * 64,
+    }
+    base.update(kwargs)
+
+    with pytest.raises(ContractComplianceError, match=message):
+        StaticWeightedMemberEstimate(**base)
+
+
+def test_auxiliary_prediction_key_mismatch_fails_before_output() -> None:
