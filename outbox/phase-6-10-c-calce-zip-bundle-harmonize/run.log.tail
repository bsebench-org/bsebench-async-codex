+def _dyn_df(step_counts: dict[int, int]) -> pd.DataFrame:
+    rows = []
+    t = 100.0
+    for step_index, count in step_counts.items():
+        for row_idx in range(count):
+            rows.append(
+                {
+                    "Test_Time(s)": t,
+                    "Step_Index": step_index,
+                    "Current(A)": -1.0 + row_idx * 0.001,
+                    "Voltage(V)": 3.3 - row_idx * 0.0001,
+                    "Temperature (C)_1": 25.0,
+                }
+            )
+            t += 1.0
+    return pd.DataFrame(rows)
+
+
+def _run_dyn_mock(tmp_path: Path, df: pd.DataFrame, *, temp_c: int = 25) -> dict[str, Path]:
+    zip_path = tmp_path / DYN_T_TO_ZIP[temp_c]
+    zip_path.write_bytes(b"fake zip bytes")
+    fake_xlsx = str(tmp_path / "A1-007.xlsx")
+
+    xls = MagicMock()
+    xls.sheet_names = ["Info", "Channel_1-001"]
+    with (
+        patch("bsebench_datasets.adapters.calce_a123_2014.zipfile.ZipFile") as zip_cls,
+        patch("bsebench_datasets.adapters.calce_a123_2014.glob.glob", return_value=[fake_xlsx]),
+        patch("pandas.ExcelFile", return_value=xls),
+        patch("pandas.read_excel", return_value=df),
+    ):
+        zip_cls.return_value.__enter__.return_value.extractall.return_value = None
+        return CalceA123Adapter(local_root=tmp_path).harmonize(output_dir=tmp_path / "out")
+
+
