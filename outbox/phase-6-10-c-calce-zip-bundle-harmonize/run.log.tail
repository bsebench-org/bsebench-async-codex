             written[cell_id] = out_path
 
+        pd = None
+        for temp_c, zip_name in DYN_T_TO_ZIP.items():
+            zip_path = self.local_root / zip_name
+            if not zip_path.is_file():
+                continue
+
+            if pd is None:
+                import pandas as pd
+
+            with tempfile.TemporaryDirectory() as tmp:
+                with zipfile.ZipFile(zip_path) as zf:
+                    zf.extractall(tmp)
+
+                xlsx_files = sorted(glob.glob(os.path.join(tmp, "**", "*.xlsx"), recursive=True))
+                for cell_idx, xlsx_path in enumerate(xlsx_files[:2]):
+                    xls = pd.ExcelFile(xlsx_path, engine="openpyxl")
+                    channel_sheets = [
+                        sheet for sheet in xls.sheet_names if sheet.startswith("Channel_")
+                    ]
+                    if not channel_sheets:
+                        print(f"CALCE A123 dynamic warning: no Channel_* sheet in {xlsx_path}")
+                        continue
+
+                    df = pd.read_excel(xls, sheet_name=channel_sheets[0])
+                    for profile, step_index in DYN_PROFILE_TO_STEP.items():
+                        segment = df[df["Step_Index"] == step_index].reset_index(drop=True)
+                        if len(segment) < 100:
+                            print(
+                                "CALCE A123 dynamic warning: "
+                                f"{profile} T={temp_c} cell={cell_idx} "
+                                f"Step_Index={step_index} has {len(segment)} rows; skipping"
+                            )
+                            continue
+
+                        t_arr = segment["Test_Time(s)"].to_numpy(dtype=np.float64)
+                        table = pa.table(
+                            {
+                                "time_s": t_arr - t_arr[0],
+                                "voltage_V": segment["Voltage(V)"].to_numpy(dtype=np.float64),
+                                "current_A": segment["Current(A)"].to_numpy(dtype=np.float64),
+                                "temperature_C": segment["Temperature (C)_1"].to_numpy(
+                                    dtype=np.float64
+                                ),
+                            }
+                        )
+                        cell_id = f"A123_{profile}_T{temp_c}_cell{cell_idx}"
+                        out_path = (
+                            output_dir
+                            / f"calce_a123_dyn_{profile}_T{temp_c}_cell{cell_idx}.parquet"
+                        )
+                        pq.write_table(table, out_path)
+                        written[cell_id] = out_path
+
         return written
