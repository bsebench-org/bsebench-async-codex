+def _config_from_residuals(
+    label: str,
+    residuals_by_filter: Mapping[str, Sequence[float]],
+) -> dict[str, object]:
+    sample_counts = {len(values) for values in residuals_by_filter.values()}
+    assert len(sample_counts) == 1
+    sample_count = sample_counts.pop()
+    return {
+        "status": "ok",
+        "config": {"label": label},
+        "retained_samples": sample_count,
+        "filters": {
+            filter_label: _ok_filter(values) for filter_label, values in residuals_by_filter.items()
+        },
+    }
+
+
 def _trace_payload() -> dict[str, object]:
     variances = [
         {"EKF": 1.0, "Hinf": 2.0, "UKFDef": 3.0},
@@ -74,8 +91,7 @@
