+def _evidence_payload_from_trace(trace: dict[str, object]) -> dict[str, object]:
     return {
         "schema_version": "1.0",
         "script": "scripts/hinf_residual_evidence_5x5.py",
@@ -101,6 +117,37 @@
     }
 
 
+def _evidence_payload() -> dict[str, object]:
+    return _evidence_payload_from_trace(_trace_payload())
+
+
+def _correlation_trace_payload(*, unstable: bool) -> dict[str, object]:
+    labels = ["cfg_a", "NASA B0005 T24", "cfg_b"]
+    hinf = [-3.5, -2.5, -1.5, -0.5, 0.5, 1.5, 2.5, 3.5]
+    if unstable:
+        ekf = [-3.0, -1.0, 0.0, 1.0, 2.0, 3.0, 0.0, 1.0]
+    else:
+        ekf = list(hinf)
+    residuals = {
+        "EKF": ekf,
+        "Hinf": hinf,
+        "UKFDef": [value * 2.0 for value in hinf],
+    }
+    return {
+        "schema_version": "1.0",
+        "script": "scripts/residual_trace_5x5.py",
+        "config_labels": labels,
+        "filter_labels": list(FILTER_LABELS),
+        "summary": {
+            "ok_configs": 3,
+            "error_configs": 0,
+            "ok_filter_runs": 9,
+            "error_filter_runs": 0,
+        },
+        "configs": {label: _config_from_residuals(label, residuals) for label in labels},
+    }
+
+
