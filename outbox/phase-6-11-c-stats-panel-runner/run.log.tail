+
+def _finite_2d_rmse(rmse_matrix: np.ndarray) -> np.ndarray:
+    try:
+        rmse = np.asarray(rmse_matrix, dtype=float)
+    except (TypeError, ValueError) as exc:
+        raise ValueError("rmse_matrix must be a numeric 2D array") from exc
+
+    if rmse.ndim != 2:
+        raise ValueError("rmse_matrix must be 2D with shape (n_configs, n_filters)")
+    if not np.all(np.isfinite(rmse)):
+        raise ValueError("rmse_matrix must contain only finite values")
+    return rmse
+
+
+def _filter_names(names: Sequence[str], n_filters: int) -> list[str]:
+    if isinstance(names, (str, bytes)):
+        raise ValueError("filter_names must be a sequence of names")
+
+    filter_names = list(names)
+    if len(filter_names) != n_filters:
+        raise ValueError("filter_names length must equal rmse_matrix.shape[1]")
+    if any(not isinstance(name, str) or not name for name in filter_names):
+        raise ValueError("filter_names must contain non-empty strings")
+    if len(set(filter_names)) != len(filter_names):
+        raise ValueError("filter_names must be unique")
+    return filter_names
+
+
+def _json_float(value: float) -> float | None:
+    value = float(value)
+    if math.isfinite(value):
+        return value
+    return None
+
+
+def _spearman_matrix(rmse: np.ndarray) -> list[list[float | None]]:
+    ranks = rankdata(rmse, axis=0, method="average")
+    with np.errstate(invalid="ignore", divide="ignore"):
+        corr = np.corrcoef(ranks, rowvar=False)
+
+    corr = np.asarray(corr, dtype=float)
+    if corr.ndim == 0:
+        corr = np.array([[1.0]])
+    np.fill_diagonal(corr, 1.0)
+    return [[_json_float(value) for value in row] for row in corr]
+
+
+def _significant_pairs(
+    names: list[str],
+    average_ranks: np.ndarray,
+    significant: np.ndarray,
+) -> list[list[str]]:
+    pairs: list[list[str]] = []
+    sorted_idx = list(np.argsort(average_ranks))
+    for pos, i in enumerate(sorted_idx):
+        for j in sorted_idx[pos + 1 :]:
+            if bool(significant[i, j]):
+                pairs.append([names[int(i)], names[int(j)]])
+    return pairs
+
+
+def run_friedman_panel(
+    rmse_matrix: np.ndarray,
+    filter_names: Sequence[str],
+    alpha: float = 0.05,
+) -> dict[str, object]:
+    """Return panel statistics for an RMSE matrix.
+
+    ``rmse_matrix`` uses shape ``(n_configs, n_filters)``. Lower RMSE is
+    better, matching the lower-level :func:`bsebench_stats.friedman_nemenyi`
+    primitives used by this runner.
+    """
+    rmse = _finite_2d_rmse(rmse_matrix)
+    n_configs, n_filters = rmse.shape
+    names = _filter_names(filter_names, n_filters)
+
+    friedman = friedman_test(rmse)
+    nemenyi = nemenyi_test(friedman["ranks"], n_configs=n_configs, alpha=alpha)
+    average_ranks = np.asarray(friedman["average_ranks"], dtype=float)
+    significant = np.asarray(nemenyi["pairwise_significant"], dtype=bool)
+    significant_pairs = _significant_pairs(names, average_ranks, significant)
+
+    alpha_value = float(nemenyi["alpha"])
+    p_value = float(friedman["p_value"])
+    return {
+        "n_configs": int(n_configs),
+        "n_filters": int(n_filters),
+        "filter_names": names,
+        "average_ranks": {name: float(average_ranks[idx]) for idx, name in enumerate(names)},
+        "friedman": {
+            "chi2": float(friedman["chi2"]),
+            "df": int(friedman["df"]),
+            "p_value": p_value,
+            "alpha": alpha_value,
+        },
+        "nemenyi": {
+            "critical_difference": float(nemenyi["critical_difference"]),
+            "pairwise_significant": significant.tolist(),
+            "significant_pairs": significant_pairs,
+            "alpha": alpha_value,
+        },
+        "spearman": {
+            "filter_names": names,
+            "correlation_matrix": _spearman_matrix(rmse),
+        },
+        "verdict": {
+            "alpha": alpha_value,
+            "friedman_rejects_null": bool(p_value < alpha_value),
+            "n_nemenyi_significant_pairs": len(significant_pairs),
+        },
+    }
