+    config_lines = "\n".join(
+        f"  - {{wrapper: {wrapper}, profile: {profile}, T_C: {t_c:g}}}"
+        for wrapper, profile, t_c in configs
+    )
+    path.write_text(
+        "\n".join(
+            [
+                'schema_version: "1.0"',
+                "split_id: synthetic_audit_j",
+                "description: synthetic split for local cache manifest tests",
+                "forensic:",
+                "  source_file: synthetic.py",
+                '  source_lines: "1-3"',
+                "  source_commit: deadbeef",
+                "configs:",
+                config_lines,
+                "",
+            ]
+        ),
+        encoding="utf-8",
+    )
+    return path
+
+
+def _write_loader_parquet(
+    path: Path,
+    *,
+    n_samples: int = 12,
+    temperature_c: float = 25.0,
+) -> None:
+    time_s = np.arange(n_samples, dtype=np.float64)
+    voltage_v = np.linspace(4.0, 3.6, n_samples, dtype=np.float64)
+    current_a = np.full(n_samples, -2.0, dtype=np.float64)
+    temperature = np.full(n_samples, temperature_c, dtype=np.float64)
+    table = pa.table(
+        {
+            "time_s": pa.array(time_s, type=pa.float64()),
+            "voltage_V": pa.array(voltage_v, type=pa.float64()),
+            "current_A": pa.array(current_a, type=pa.float64()),
+            "temperature_C": pa.array(temperature, type=pa.float64()),
+        }
+    )
+    pq.write_table(table, str(path))
+
+
+def _status_by_label(payload: dict[str, object]) -> dict[str, dict[str, object]]:
+    return {str(config["label"]): config for config in payload["configs"]}  # type: ignore[index]
+
+
+def test_manifest_distinguishes_missing_unreadable_and_loader_readable(tmp_path: Path) -> None:
+    split_path = _write_split(
+        tmp_path / "split.yaml",
+        [
+            ("calce_legacy", "DST", 25.0),
+            ("panasonic", "US06", 25.0),
+            ("yao", "BCDC", 35.0),
+        ],
+    )
+    calce_root = tmp_path / "calce"
+    panasonic_root = tmp_path / "panasonic"
+    yao_root = tmp_path / "yao"
+    calce_root.mkdir()
+    panasonic_root.mkdir()
+    yao_root.mkdir()
+
+    valid_path = calce_root / "calce_a123_DST_T25.parquet"
+    _write_loader_parquet(valid_path, temperature_c=25.0)
+    corrupt_path = panasonic_root / "pan_US06_T25.parquet"
+    corrupt_path.write_bytes(b"not a parquet file")
+
+    payload = build_auditj_local_cache_manifest(
+        split_path,
+        cache_root_overrides={
+            "calce_legacy": calce_root,
+            "panasonic": panasonic_root,
+            "yao": yao_root,
+        },
+        env={},
+    )
+
+    configs = _status_by_label(payload)
+    assert configs["calce_legacy:DST:T25"]["status"] == STATUS_LOADER_READABLE
+    assert configs["panasonic:US06:T25"]["status"] == STATUS_PRESENT_UNREADABLE
+    assert configs["panasonic:US06:T25"]["gap_kind"] == "loader_read_error"
+    assert configs["yao:BCDC:T35"]["status"] == STATUS_MISSING
+    assert configs["yao:BCDC:T35"]["gap_kind"] == "missing_required_files"
+
+    calce_files = configs["calce_legacy:DST:T25"]["required_files"]
+    assert calce_files[0]["size_bytes"] == valid_path.stat().st_size  # type: ignore[index]
+    assert calce_files[0]["sha256"] == hashlib.sha256(valid_path.read_bytes()).hexdigest()  # type: ignore[index]
+    assert payload["evidence_ready"] is False
+    assert payload["summary"] == {  # type: ignore[index]
+        "configs_total": 3,
+        "present_and_loader_readable": 1,
+        "present_but_unreadable": 1,
+        "missing": 1,
+        "gap_configs": 2,
+    }
+    json.dumps(payload, allow_nan=False)
+
+
+def test_nasa_metadata_driven_manifest_resolves_selected_parquet(tmp_path: Path) -> None:
+    split_path = _write_split(tmp_path / "split.yaml", [("nasa", "CC-discharge", 24.0)])
+    nasa_root = tmp_path / "nasa"
+    nasa_root.mkdir()
+    (nasa_root / "metadata.csv").write_text(
+        "\n".join(
+            [
+                "type,start_time,ambient_temperature,battery_id,test_id,uid,filename,Capacity,Re,Rct",
+                "discharge,[2010 1 1 0 0 0],24,B0006,2,2,06000.csv,1.95,,",
+                "discharge,[2010 1 1 0 0 0],24,B0005,1,1,05000.csv,1.86,,",
+                "",
+            ]
+        ),
+        encoding="utf-8",
+    )
+    _write_loader_parquet(nasa_root / "B0005_test1.parquet", n_samples=8, temperature_c=24.0)
+
+    payload = build_auditj_local_cache_manifest(
+        split_path,
+        cache_root_overrides={"nasa": nasa_root},
+        env={},
+    )
+
+    config = payload["configs"][0]
+    assert config["status"] == STATUS_LOADER_READABLE
+    assert config["selection"] == {
+        "cell_id": "B0005",
+        "test_id": 1,
+        "selection_policy": "paper2b_preferred_fresh_cell",
+    }
+    assert [item["filename"] for item in config["required_files"]] == [  # type: ignore[index]
+        "metadata.csv",
+        "B0005_test1.parquet",
+    ]
+    assert config["load_probe"]["runtime_identity"] == {  # type: ignore[index]
+        "cell_id": "B0005",
+        "test_id": 1,
+        "T_amb": 24.0,
+    }
+    assert payload["evidence_ready"] is True
+
+
+def test_manifest_marks_missing_cache_root_as_gap(tmp_path: Path) -> None:
+    split_path = _write_split(tmp_path / "split.yaml", [("calce_legacy", "DST", 25.0)])
+
+    payload = build_auditj_local_cache_manifest(split_path, env={})
+
+    config = payload["configs"][0]
+    assert config["status"] == STATUS_MISSING
+    assert config["gap_kind"] == "missing_cache_root"
+    assert payload["evidence_ready"] is False
+    assert payload["gap_config_labels"] == ["calce_legacy:DST:T25"]
+
+
+def test_hash_size_limit_keeps_size_and_skips_digest(tmp_path: Path) -> None:
+    split_path = _write_split(tmp_path / "split.yaml", [("calce_legacy", "DST", 25.0)])
+    calce_root = tmp_path / "calce"
+    calce_root.mkdir()
+    parquet_path = calce_root / "calce_a123_DST_T25.parquet"
+    _write_loader_parquet(parquet_path)
+
+    payload = build_auditj_local_cache_manifest(
+        split_path,
+        cache_root_overrides={"calce_legacy": calce_root},
+        hash_max_bytes=1,
+        env={},
+    )
+
+    file_payload = payload["configs"][0]["required_files"][0]
+    assert file_payload["size_bytes"] == parquet_path.stat().st_size
+    assert file_payload["sha256"] is None
+    assert file_payload["hash_status"] == "skipped_size_limit"
+    assert payload["configs"][0]["status"] == STATUS_LOADER_READABLE
+
+
+def test_cache_root_override_parser_rejects_unknown_wrapper() -> None:
+    with pytest.raises(AuditJLocalCacheManifestError, match="unknown wrapper"):
+        parse_cache_root_overrides(["unknown=/tmp/cache"])

