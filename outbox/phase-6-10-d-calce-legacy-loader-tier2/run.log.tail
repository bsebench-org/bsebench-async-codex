+    CHEMISTRY_TAG,
+    DATASET_TAG,
+    CalceA123Adapter,
+)
+from bsebench_datasets.loaders import AdapterNotAvailableError
+from bsebench_datasets.loaders.calce_a123_legacy_loader import (
+    CALCE_LEGACY_HF_REPO,
+    CALCE_SOURCE_URL,
+    CalceLegacyLoader,
+)
+
+CALCE_LOCAL_RAW_ROOT = Path(
+    os.environ.get(
+        "BSEBENCH_CALCE_A123_RAW_ROOT",
+        "/mnt/c/doctorat/these_lfp_2026/ecm_fidelity_lfp/data",
+    )
+)
+
+
+def _parquet_filename(temp_c: int) -> str:
+    return f"calce_a123_DST_T{temp_c}.parquet"
+
+
+def _write_synthetic_parquet(
+    path: Path,
+    *,
+    time_start_s: float = 0.0,
+    n_samples: int = 12,
+    current_a: float = -2.0,
+    temperature_c: float = 25.0,
+) -> None:
+    time_s = time_start_s + np.arange(n_samples, dtype=np.float64)
+    voltage_v = np.linspace(3.4, 3.1, n_samples, dtype=np.float64)
+    current = np.full(n_samples, current_a, dtype=np.float64)
+    temperature = np.full(n_samples, temperature_c, dtype=np.float64)
+    table = pa.table(
+        {
+            "time_s": pa.array(time_s, type=pa.float64()),
+            "voltage_V": pa.array(voltage_v, type=pa.float64()),
+            "current_A": pa.array(current, type=pa.float64()),
+            "temperature_C": pa.array(temperature, type=pa.float64()),
+        }
+    )
+    pq.write_table(table, str(path))
+
+
+def _loader_for_parquet(
+    tmp_path: Path,
+    *,
+    temp_c: int = 25,
+    **parquet_kwargs: object,
+) -> CalceLegacyLoader:
+    parquet_path = tmp_path / _parquet_filename(temp_c)
+    _write_synthetic_parquet(parquet_path, **parquet_kwargs)
+    return CalceLegacyLoader(local_cache_root=tmp_path)
+
+
+def test_constants() -> None:
+    assert CALCE_LEGACY_HF_REPO == "bsebench-org/calce-a123-2014"
+    assert CALCE_SOURCE_URL == "https://calce.umd.edu/battery-data"
+    assert CALCE_A123_LEGACY_PROFILES == ("DST",)
+    assert CALCE_A123_LEGACY_TEMPS_C == (0, 25, 40)
+    assert DATASET_TAG == "calce_a123_lfp"
+    assert CHEMISTRY_TAG == "LFP_A123_APR18650M1A"
+
+
+def test_loader_constructor_and_wrapper_name() -> None:
+    loader = CalceLegacyLoader(downloader=lambda _: "/nonexistent")
+    assert loader.wrapper_name == "calce_legacy"
+
+
+def test_loader_available_configs() -> None:
+    assert CalceLegacyLoader().available_configs() == [("DST", 0.0), ("DST", 25.0), ("DST", 40.0)]
+
+
+def test_loader_rejects_invalid_profile() -> None:
+    loader = CalceLegacyLoader(downloader=lambda _: "/nonexistent")
+    with pytest.raises(AdapterNotAvailableError, match="CALCE profile 'FUDS' not present on disk"):
+        loader.load("FUDS", 25.0)
+
+
+def test_loader_rejects_invalid_temperature() -> None:
+    loader = CalceLegacyLoader(downloader=lambda _: "/nonexistent")
+    with pytest.raises(AdapterNotAvailableError, match=r"CALCE DST unavailable at T=50\.0C"):
+        loader.load("DST", 50.0)
+
+
+def test_loader_cell_id_t25(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, temp_c=25)
+    out = loader.load("DST", 25.0)
+    assert out["cell_id"] == "A123_T25"
+
+
+def test_loader_cell_id_t0(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, temp_c=0)
+    out = loader.load("DST", 0.0)
+    assert out["cell_id"] == "A123_T0"
+
+
+def test_loader_cell_id_t40(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, temp_c=40)
+    out = loader.load("DST", 40.0)
+    assert out["cell_id"] == "A123_T40"
+
+
+def test_loader_flips_bpx_current_to_discharge_positive(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, current_a=-3.0)
+    out = loader.load("DST", 25.0)
+    assert np.allclose(out["I"], 3.0)
+
+
+def test_loader_rebases_time_to_zero(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, time_start_s=100.0)
+    out = loader.load("DST", 25.0)
+    assert out["t"][0] == 0.0
+
+
+def test_loader_schema_keys(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path)
+    out = loader.load("DST", 25.0)
+    assert set(out) == {
+        "t",
+        "V",
+        "I",
+        "T_meas",
+        "N",
+        "T_amb",
+        "cell_id",
+        "dataset",
+        "chemistry",
+        "source_url",
+    }
+
+
+def test_loader_length_consistency(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path, n_samples=17)
+    out = loader.load("DST", 25.0)
+    n = out["N"]
+    assert len(out["t"]) == len(out["V"]) == len(out["I"]) == len(out["T_meas"]) == n
+
+
+def test_loader_metadata_values(tmp_path: Path) -> None:
+    loader = _loader_for_parquet(tmp_path)
+    out = loader.load("DST", 25.0)
+    assert out["T_amb"] == 25.0
+    assert out["dataset"] == "calce_a123_lfp"
+    assert out["chemistry"] == "LFP_A123_APR18650M1A"
+    assert out["source_url"] == "https://calce.umd.edu/battery-data"
+
+
+def test_loader_downloader_receives_expected_filename(tmp_path: Path) -> None:
+    parquet_path = tmp_path / _parquet_filename(25)
+    _write_synthetic_parquet(parquet_path)
+    calls: list[str] = []
+
+    def downloader(filename: str) -> str:
+        calls.append(filename)
+        return str(parquet_path)
+
+    loader = CalceLegacyLoader(downloader=downloader)
+    out = loader.load("DST", 25.0)
+    assert calls == ["calce_a123_DST_T25.parquet"]
+    assert out["cell_id"] == "A123_T25"
+
+
+@pytest.mark.slow
+def test_loader_calce_legacy_dst_t25_paper2b_compat(tmp_path: Path) -> None:
+    raw_root = CALCE_LOCAL_RAW_ROOT
+    raw_csv = raw_root / "A123_25C.csv"
+    if not raw_csv.is_file():
+        pytest.skip(f"local CALCE A123 CSV not found at {raw_csv}")
+
+    written = CalceA123Adapter(local_root=raw_root).harmonize(output_dir=tmp_path)
+    assert "A123_T25" in written
+
+    loader = CalceLegacyLoader(local_cache_root=tmp_path)
+    out = loader.load("DST", 25.0)
+    assert out["cell_id"] == "A123_T25"
+    assert out["chemistry"] == "LFP_A123_APR18650M1A"
+    assert out["N"] > 1000
+    assert out["t"][0] == 0.0

