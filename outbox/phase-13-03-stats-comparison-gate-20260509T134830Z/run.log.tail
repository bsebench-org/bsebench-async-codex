+    assert first["metrics"] == {
+        "soc_rmse": pytest.approx(0.21),
+        "soc_mae": pytest.approx(0.16),
+    }
+    assert first["uncertainty"]["soc_rmse"]["interval"] == {
+        "lower": pytest.approx(0.19),
+        "upper": pytest.approx(0.24),
+    }
+    json.dumps(report, allow_nan=False)
+
+
+@pytest.mark.fast
+def test_extract_phase13_comparison_metric_matrix_validates_gate_first() -> None:
+    matrix = extract_phase13_comparison_metric_matrix(
+        _candidates(),
+        required_metric_keys=["soc_rmse", "soc_mae"],
+    )
+
+    assert matrix == {
+        "ensemble_a": {
+            "soc_rmse": pytest.approx(0.21),
+            "soc_mae": pytest.approx(0.16),
+        },
+        "ensemble_b": {
+            "soc_rmse": pytest.approx(0.24),
+            "soc_mae": pytest.approx(0.19),
+        },
+    }
+
+
+@pytest.mark.fast
+@pytest.mark.parametrize(
+    ("mutation", "message"),
+    [
+        (
+            lambda payload: payload[0].pop("provenance"),
+            r"candidate_reports\[0\]\.provenance",
+        ),
+        (
+            lambda payload: payload[0]["provenance"].pop("artifact_sha256"),
+            r"provenance\.artifact_sha256",
+        ),
+        (
+            lambda payload: payload[0]["provenance"].update({"artifact_sha256": "not-a-hash"}),
+            "must be a sha256 digest",
+        ),
+        (
+            lambda payload: payload[0].pop("evidence"),
+            r"candidate_reports\[0\]\.evidence",
+        ),
+        (
+            lambda payload: payload[0]["evidence"].pop("sha256"),
+            r"evidence\.sha256",
+        ),
+        (
+            lambda payload: payload[0].pop("split_ids"),
+            r"candidate_reports\[0\]\.split_ids",
+        ),
+        (
+            lambda payload: payload[0].update({"split_ids": []}),
+            r"split_ids must be a non-empty sequence",
+        ),
+        (
+            lambda payload: payload[1].update({"split_ids": ["other/test"]}),
+            "split_ids must match the first candidate exactly",
+        ),
+        (
+            lambda payload: payload[1]["metrics"].pop("soc_mae"),
+            "keys must match expected metric keys exactly",
+        ),
+        (
+            lambda payload: payload[1]["metrics"].update({"soc_bias": 0.02}),
+            "keys must match expected metric keys exactly",
+        ),
+        (
+            lambda payload: payload[1]["uncertainty"].pop("soc_mae"),
+            r"uncertainty keys must match metric keys exactly",
+        ),
+        (
+            lambda payload: payload[0]["ensemble"]["members"][0]["provenance"].pop(
+                "dataset_fingerprint"
+            ),
+            "dataset_fingerprint",
+        ),
+    ],
+)
+def test_phase13_comparison_gate_missing_evidence_fails_closed(mutation, message: str) -> None:
+    payload = deepcopy(_candidates())
+    mutation(payload)
+
+    with pytest.raises(Phase13ComparisonGateError, match=message):
+        validate_phase13_comparison_readiness(payload)
+
+
+@pytest.mark.fast
+@pytest.mark.parametrize(
+    ("mutation", "message"),
+    [
+        (
+            lambda payload: payload[0]["metrics"].update({"soc_rmse": float("inf")}),
+            r"metrics\.soc_rmse must be a finite number",
+        ),
+        (
+            lambda payload: payload[0]["metrics"].update({"soc_rmse": True}),
+            r"metrics\.soc_rmse must be a finite number",
+        ),
+        (
+            lambda payload: payload[0]["uncertainty"]["soc_rmse"].update({"lower": 0.4}),
+            "lower must be <= upper",
+        ),
+        (
+            lambda payload: payload[0]["uncertainty"]["soc_rmse"].update({"upper": 0.2}),
+            "interval must contain metric value",
+        ),
+        (
+            lambda payload: payload[0]["uncertainty"]["soc_rmse"].update({"standard_error": -0.01}),
+            "standard_error must be non-negative",
+        ),
+        (
+            lambda payload: payload[0]["uncertainty"]["soc_rmse"].update({"sample_count": 1}),
+            "sample_count must be at least 2",
+        ),
+    ],
+)
+def test_phase13_comparison_gate_invalid_values_fail_closed(
+    mutation,
+    message: str,
+) -> None:
+    payload = deepcopy(_candidates())
+    mutation(payload)
+
+    with pytest.raises(Phase13ComparisonGateError, match=message):
+        validate_phase13_comparison_readiness(payload)
+
+
