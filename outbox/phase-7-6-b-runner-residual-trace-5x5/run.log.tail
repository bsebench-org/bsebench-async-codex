+@pytest.mark.fast
+def test_require_ok_configs_prevents_output_writing(trace_module, tmp_path: Path, capsys) -> None:
+    config = trace_module.SweepConfig("Broken Config", "broken", "P1", 25.0)
+    filters = (trace_module.SweepFilter("ok", "ok"),)
+    output_path = tmp_path / "should_not_exist.json"
+
+    def failing_loader(profile: str, t_c: float) -> dict[str, Any]:
+        del profile, t_c
+        raise RuntimeError("synthetic loader failure")
+
+    rc = trace_module.main(
+        [
+            "--output",
+            str(output_path),
+            "--n-max",
+            "5",
+            "--warmup-samples",
+            "1",
+            "--require-ok-configs",
+            "1",
+            "--require-ok-filter-runs",
+            "0",
+        ],
+        adapter_factories={"broken": lambda: failing_loader},
+        filter_factories={"ok": lambda: _BiasFilter(0.001)},
+        config_targets=(config,),
+        filter_targets=filters,
+    )
+
+    captured = capsys.readouterr()
+    assert rc == 2
+    assert not output_path.exists()
+    assert "summary: ok_configs=0, error_configs=1" in captured.out
+    assert "ok_configs=0/1" in captured.err
+
+
