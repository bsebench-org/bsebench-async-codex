+    assert serialized["filter_labels"] == ["plus_1mV", "minus_2mV"]
+    assert serialized["summary"] == {
+        "ok_configs": 2,
+        "error_configs": 0,
+        "ok_filter_runs": 4,
+        "error_filter_runs": 0,
+    }
+    assert payload["summary"] == serialized["summary"]
+
+    config_a = serialized["configs"]["Config A"]
+    assert config_a["status"] == "ok"
+    assert config_a["retained_samples"] == 3
+    assert config_a["warmup_samples"] == 2
+    assert config_a["validation_window"] == {"start_index": 2, "end_index": 5}
+    assert config_a["time_s"] == pytest.approx([2.0, 3.0, 4.0])
+    assert config_a["measured_voltage_mV"] == pytest.approx([3032.0, 3042.0, 3052.0])
+
+    plus = config_a["filters"]["plus_1mV"]
+    minus = config_a["filters"]["minus_2mV"]
+    assert plus["status"] == "ok"
+    assert plus["retained_samples"] == 3
+    assert plus["residual_mV"] == pytest.approx([1.0, 1.0, 1.0])
+    assert minus["residual_mV"] == pytest.approx([-2.0, -2.0, -2.0])
+    assert "predicted_voltage_mV" not in plus
+    assert "measured_voltage_mV" not in plus
+
