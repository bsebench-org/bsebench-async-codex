+def test_failing_loader_marks_config_error_without_residual_arrays(trace_module) -> None:
+    config = trace_module.SweepConfig("Broken Config", "broken", "P1", 25.0)
+    filters = (trace_module.SweepFilter("plus_1mV", "plus"),)
+
+    def failing_loader(profile: str, t_c: float) -> dict[str, Any]:
+        del profile, t_c
+        raise FileNotFoundError("synthetic loader failure")
+
+    payload = trace_module.run_residual_trace_5x5(
+        output_path=None,
+        adapter_factories={"broken": lambda: failing_loader},
+        filter_factories={"plus_1mV": lambda: _BiasFilter(0.001)},
+        config_targets=(config,),
+        filter_targets=filters,
+        n_max=5,
+        warmup_samples=1,
+        require_ok_configs=0,
+        require_ok_filter_runs=0,
+    )
+
+    config_payload = payload["configs"]["Broken Config"]
+    assert config_payload["status"] == "error"
+    assert config_payload["reason"] == "config_load_failed"
+    assert config_payload["error"]["type"] == "FileNotFoundError"
+    assert "measured_voltage_mV" not in config_payload
+    assert "time_s" not in config_payload
+    assert config_payload["filters"] == {}
+    assert payload["summary"]["error_configs"] == 1
+
