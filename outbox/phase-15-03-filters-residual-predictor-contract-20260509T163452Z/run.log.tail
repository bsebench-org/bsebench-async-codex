+def test_residual_predictor_manifest_requires_evidence_hashes_and_finite_metadata(
+    mutation: Callable[[MutableMapping[str, object]], object],
+    message: str,
+) -> None:
+    manifest = deepcopy(_valid_manifest())
+    mutation(manifest)
+
+    with pytest.raises(ResidualPredictorManifestValidationError, match=message):
+        validate_phase15_residual_predictor_manifest(manifest)
+    assert residual_predictor_blocking_gaps(manifest)
+
+
+@pytest.mark.parametrize(
+    ("mutation", "message"),
+    [
+        (
+            lambda payload: payload["predictor"].update({"fit_command": "python train.py"}),
+            r"manifest\.predictor\.fit_command is forbidden",
+        ),
+        (
+            lambda payload: payload["predictor"].update({"predict_fn": "module.callable"}),
+            r"manifest\.predictor\.predict_fn is forbidden",
+        ),
+        (
+            lambda payload: payload["predictor"].update({"framework_import": "torch"}),
+            r"manifest\.predictor\.framework_import is forbidden",
+        ),
+        (
+            lambda payload: payload["evidence"].update({"real_trace_samples": ["trace-001"]}),
+            r"manifest\.evidence\.real_trace_samples is forbidden",
+        ),
+        (
+            lambda payload: payload["execution_policy"].update({"training_allowed": True}),
+            r"execution_policy\.training_allowed must remain false",
+        ),
+        (
+            lambda payload: payload["execution_policy"].update(
+                {"predictor_execution_allowed": True}
+            ),
+            r"execution_policy\.predictor_execution_allowed must remain false",
+        ),
+        (
+            lambda payload: payload["predictor"]["inputs"].update({"uses_future_samples": True}),
+            r"predictor\.inputs\.uses_future_samples must remain false",
+        ),
+    ],
+)
+def test_residual_predictor_manifest_blocks_training_execution_and_real_trace_fields(
+    mutation: Callable[[MutableMapping[str, object]], object],
+    message: str,
+) -> None:
+    manifest = deepcopy(_valid_manifest())
+    mutation(manifest)
+
+    with pytest.raises(ResidualPredictorManifestValidationError, match=message):
+        validate_phase15_residual_predictor_manifest(manifest)
+
+
+@pytest.mark.parametrize(
+    ("mutation", "message"),
+    [
+        (
+            lambda payload: payload["evidence"]["split_ids"].update(
+                {"holdout": "synthetic-phase15-validation"}
+            ),
+            "evidence.split_ids must separate fit, validation, and holdout splits",
+        ),
+        (
+            lambda payload: payload["evidence"]["split_ids"].update({"fit": "all"}),
+            r"evidence\.split_ids\.fit must identify a non-leaky split",
+        ),
+        (
+            lambda payload: payload["predictor"]["inputs"]["feature_names"].append(
+                "future_voltage_label"
+            ),
+            "leakage-prone feature",
+        ),
+    ],
+)
+def test_residual_predictor_manifest_fails_closed_for_split_or_feature_leakage(
+    mutation: Callable[[MutableMapping[str, object]], object],
+    message: str,
+) -> None:
+    manifest = deepcopy(_valid_manifest())
+    mutation(manifest)
+
+    with pytest.raises(ResidualPredictorManifestValidationError, match=message):
+        validate_phase15_residual_predictor_manifest(manifest)
+
+
+@pytest.mark.parametrize(
+    ("mutation", "message"),
+    [
+        (
+            lambda payload: payload.update({"claim_status": "GO_CLAIM"}),
+            "claim_status must remain NO_GO_CLAIM",
