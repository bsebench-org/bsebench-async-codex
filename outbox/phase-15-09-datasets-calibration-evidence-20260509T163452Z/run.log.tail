+        gate,
+        tmp_path / "outputs" / "phase15_calibration_evidence_gate.json",
+    )
+
+    loaded = json.loads(path.read_text(encoding="utf-8"))
+    assert loaded == gate
+    assert path.read_text(encoding="utf-8").endswith("\n")
+
+
+def test_gate_blocks_evaluation_overlap_and_missing_provenance(
+    tmp_path: Path,
+) -> None:
+    gate = build_phase15_calibration_evidence_gate(
+        manifest_id="phase15_calibration_fixture",
+        generated_at="2026-05-09T16:34:52Z",
+        bundles=[
+            _bundle(
+                tmp_path,
+                evaluation_windows=[
+                    _window(
+                        tmp_path,
+                        split_id="evaluation_v1",
+                        window_id="eval_001",
+                        start=9.0,
+                        end=12.0,
+                    )
+                ],
+                residual_scope=_residual_scope(tmp_path, provenance={}),
+                provenance={},
+            )
+        ],
+    )
+
+    bundle = gate["bundles"][0]
+    assert gate["status"] == "blocked"
+    assert gate["decision"]["adaptive_filter_learning_preflight_allowed"] is False
+    assert "evaluation_window_overlap" in bundle["blocking_gaps"]
+    assert "provenance.missing_provenance" in bundle["blocking_gaps"]
+    assert "residual_scope.provenance.missing_provenance" in bundle["blocking_gaps"]
+    assert "overlaps_evaluation_window" in bundle["calibration_windows"][0]["blocking_gaps"]
+    assert "overlaps_calibration_window" in bundle["evaluation_windows"][0]["blocking_gaps"]
+
+
+def test_gate_fails_closed_on_invalid_hash_and_non_finite_windows(
+    tmp_path: Path,
+) -> None:
+    invalid_source = CalibrationEvidenceSource(
+        uri="artifact://unit/invalid-source.json",
+        sha256="not-a-sha256",
+    )
+
+    gate = build_phase15_calibration_evidence_gate(
+        manifest_id="phase15_calibration_fixture",
+        generated_at="2026-05-09T16:34:52Z",
+        bundles=[
+            _bundle(
+                tmp_path,
+                calibration_windows=[
+                    _window(
+                        tmp_path,
+                        split_id="calibration_v1",
+                        window_id="cal_001",
+                        start=float("nan"),
+                        end=10.0,
+                        source=invalid_source,
+                    )
+                ],
+            )
+        ],
+    )
+
+    window = gate["bundles"][0]["calibration_windows"][0]
+    assert gate["status"] == "blocked"
+    assert "non_finite_calibration_window_start" in window["blocking_gaps"]
+    assert "source.invalid_source_hash" in window["blocking_gaps"]
+    assert window["start"] is None
+    json.dumps(gate, allow_nan=False)
+
+
+def test_gate_fails_closed_when_window_axes_are_incomparable(tmp_path: Path) -> None:
+    gate = build_phase15_calibration_evidence_gate(
+        manifest_id="phase15_calibration_fixture",
+        generated_at="2026-05-09T16:34:52Z",
+        bundles=[
