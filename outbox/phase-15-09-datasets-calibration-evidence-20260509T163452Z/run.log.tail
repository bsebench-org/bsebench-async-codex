+def test_gate_blocks_residual_scope_leakage_and_forbidden_adaptive_claim(
+    tmp_path: Path,
+) -> None:
+    gate = build_phase15_calibration_evidence_gate(
+        manifest_id="phase15_calibration_fixture",
