+                        start=10.0,
+                        end=20.0,
+                        axis="time_s",
+                        unit="s",
+                    )
+                ],
+            )
+        ],
+    )
+
+    bundle = gate["bundles"][0]
+    assert gate["status"] == "blocked"
+    assert "evaluation_window_axis_unit_mismatch" in bundle["blocking_gaps"]
+    assert (
+        "incomparable_evaluation_window_axis_unit"
+        in bundle["calibration_windows"][0]["blocking_gaps"]
+    )
+
