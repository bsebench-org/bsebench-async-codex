+from tests.test_hinf_residual_sensitivity import _evidence_payload
+
+STABLE_CONFIG_LABELS = ["cfg_long_a", "NASA B0005 T24", "cfg_long_b"]
+STABLE_FILTER_LABELS = ["EKF", "Hinf", "UKFDef"]
+
+
+def _ok_filter(values: Sequence[float]) -> dict[str, object]:
+    return {"status": "ok", "residual_mV": list(values)}
+
+
+def _residuals_for_variance(residual_var_m_v2: float, sample_count: int) -> list[float]:
+    pattern = [-1.0 if index % 2 == 0 else 1.0 for index in range(sample_count)]
+    pattern_var = sample_count / (sample_count - 1)
+    scale = math.sqrt(residual_var_m_v2 / pattern_var)
+    return [scale * value for value in pattern]
+
+
+def _config(
+    label: str,
+    sample_count: int,
+    variances_by_filter: Mapping[str, float],
+) -> dict[str, object]:
+    return {
+        "status": "ok",
+        "config": {"label": label},
+        "retained_samples": sample_count,
+        "filters": {
+            filter_label: _ok_filter(_residuals_for_variance(variance, sample_count))
+            for filter_label, variance in variances_by_filter.items()
+        },
+    }
 
 
+def _stable_trace_payload() -> dict[str, object]:
+    sample_count = 20
+    variances = [
+        {"EKF": 1.0, "Hinf": 2.0, "UKFDef": 3.0},
+        {"EKF": 1.1, "Hinf": 2.1, "UKFDef": 3.1},
+        {"EKF": 1.2, "Hinf": 2.2, "UKFDef": 3.2},
+    ]
+    return {
+        "schema_version": "1.0",
+        "script": "scripts/residual_trace_5x5.py",
+        "config_labels": list(STABLE_CONFIG_LABELS),
+        "filter_labels": list(STABLE_FILTER_LABELS),
+        "summary": {
+            "ok_configs": 3,
+            "error_configs": 0,
+            "ok_filter_runs": 9,
+            "error_filter_runs": 0,
+        },
+        "configs": {
+            config_label: _config(config_label, sample_count, config_variances)
+            for config_label, config_variances in zip(
+                STABLE_CONFIG_LABELS,
+                variances,
+                strict=True,
+            )
+        },
+    }
+
+
+def _stable_evidence_payload() -> dict[str, object]:
+    trace = _stable_trace_payload()
+    return {
+        "schema_version": "1.0",
+        "script": "scripts/hinf_residual_evidence_5x5.py",
+        "scientific_verdict": "none",
+        "claim_target": "new_hinf_candidate_not_claim_55",
+        "mechanical_evidence_only": True,
+        "claim_55_targeted": False,
+        "requirements": {
