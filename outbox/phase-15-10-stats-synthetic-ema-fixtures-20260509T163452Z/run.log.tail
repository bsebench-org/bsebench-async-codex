+@pytest.mark.fast
+def test_paired_delta_gate_payload_passes_and_matches_reference() -> None:
+    fixture = _load_fixture()
+    expected = fixture["expected_reference"]
+    gate_report = _build_delta_gate_report(fixture["adaptive_delta_gate_input"])
+
+    assert gate_report["schema_version"] == DELTA_GATE_SCHEMA_VERSION
+    assert gate_report["source_schema_version"] == DELTA_GATE_INPUT_SCHEMA_VERSION
+    assert gate_report["gate_status"] == "passed"
+    assert gate_report["mechanical_validation_only"] is True
+    assert gate_report["adaptive_tooling_preflight_only"] is True
+    assert gate_report["metric_keys"] == expected["metric_keys"]
+    assert gate_report["blocking_gaps"] == []
+    assert gate_report["release_gate"]["pass"] is True
+    assert gate_report["release_gate"]["claim_authorization"] == "refused_by_default"
+
+    paired_rows = gate_report["paired_delta_rows"]
+    expected_rows = expected["paired_deltas"]
+    assert [row["pair_id"] for row in paired_rows] == [row["pair_id"] for row in expected_rows]
+    for row, expected_row in zip(paired_rows, expected_rows, strict=True):
+        assert row["deltas"]["absolute_residual"] == pytest.approx(
+            expected_row["absolute_residual"]
+        )
+        assert row["deltas"]["squared_residual"] == pytest.approx(expected_row["squared_residual"])
+    for metric_key, expected_summary in expected["delta_summary"].items():
+        assert gate_report["delta_summary"][metric_key] == pytest.approx(expected_summary)
+    json.dumps(gate_report, allow_nan=False)
+    _assert_json_finite(gate_report)
+
