+    parser.add_argument(
+        "--n-max",
+        type=int,
+        default=_env_int("BSEBENCH_CHI2_SMOKE_N_MAX", DEFAULT_N_MAX),
+        help="Maximum samples to evaluate.",
+    )
+    parser.add_argument(
+        "--warmup-samples",
+        type=int,
+        default=_env_int("BSEBENCH_CHI2_SMOKE_WARMUP", DEFAULT_WARMUP_SAMPLES),
+        help="Samples to exclude from residual chi-square.",
+    )
+    parser.add_argument(
+        "--sigma-v",
+        type=float,
+        default=None,
+        help="Override voltage sensor sigma in volts.",
+    )
+    return parser.parse_args(argv)
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = parse_args(argv)
+    payload = run_smoke(
+        local_cache_root=args.local_cache_root,
+        output_path=args.output,
+        n_max=args.n_max,
+        warmup_samples=args.warmup_samples,
+        sigma_v=args.sigma_v,
+    )
+
+    print(f"Yao BCDC T25 chi2 smoke, sigma={payload['sensor_noise']['sigma_mV']:.6g} mV")
+    for name, result in payload["filters"].items():
+        print(
+            f"{name}: chi2={result['chi2']:.6g}, "
+            f"df={result['df']}, p={result['p_value']:.6g}, "
+            f"rmse={result['rmse_mV']:.6g} mV"
+        )
+    print(
+        "paper2b Friedman reference "
+        f"chi2={PAPER2B_FRIEDMAN_CHI2_REFERENCE:.3f} (not directly comparable)"
+    )
+    print(f"wrote {args.output}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
