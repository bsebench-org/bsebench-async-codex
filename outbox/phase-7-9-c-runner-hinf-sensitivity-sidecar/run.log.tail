+        "material_sensitivity": {
+            "status": material_status,
+            "risk_count": len(risk_ids),
+            "risk_ids": risk_ids,
+            "caution": caution,
+        },
+        "falsification_gate": falsification_gate,
+        "stats_sensitivity": stats_payload,
+    }
+    _assert_finite_numbers(payload, "hinf_residual_sensitivity_sidecar")
+    json_payload = json.dumps(payload, indent=2, sort_keys=True, allow_nan=False) + "\n"
+    output_file = Path(output_path)
+    output_file.parent.mkdir(parents=True, exist_ok=True)
+    output_file.write_text(json_payload, encoding="utf-8")
+    return payload
+
+
+def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--stats-output", required=True, help="JSON emitted by stats sensitivity CLI."
+    )
+    parser.add_argument("--evidence", default=str(DEFAULT_EVIDENCE_PATH))
+    parser.add_argument("--output", default=str(DEFAULT_OUTPUT_PATH))
+    parser.add_argument("--stats-repo", default=str(DEFAULT_STATS_REPO))
+    parser.add_argument("--stats-ref", default="main")
+    parser.add_argument("--stats-git-sha")
+    parser.add_argument(
+        "--stats-command",
+        default="",
+        help="Exact stats command used to create --stats-output.",
+    )
+    return parser.parse_args(argv)
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = parse_args(argv)
+    try:
+        sidecar = build_hinf_residual_sensitivity_sidecar(
+            stats_output_path=args.stats_output,
+            evidence_path=args.evidence,
+            output_path=args.output,
+            stats_repo=args.stats_repo,
+            stats_ref=args.stats_ref,
+            stats_git_sha=args.stats_git_sha,
+            stats_command=args.stats_command,
+        )
+    except HinfResidualSensitivitySidecarError as exc:
+        print(f"hinf residual sensitivity sidecar build failed: {exc}")
+        return 2
+    material = sidecar["material_sensitivity"]
+    print("hinf residual sensitivity sidecar build ok")
+    print(f"output: {args.output}")
+    print(f"material sensitivity: {material['status']} risks={material['risk_count']}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
