+        target_filter=target_filter,
+        short_config_label=short_config_label,
+        share_delta_material_threshold=share_delta_material_threshold,
+        effect_delta_material_threshold=effect_delta_material_threshold,
+        correlation_delta_material_threshold=correlation_delta_material_threshold,
+        sample_imbalance_ratio_threshold=sample_imbalance_ratio_threshold,
+    )
+    source = {
+        "evidence_path": str(Path(evidence_path)),
+    }
+    payload = {**payload, "source": source}
+    json_payload = json.dumps(payload, indent=2, sort_keys=True, allow_nan=False) + "\n"
+    if output_path is not None:
+        out_path = Path(output_path)
+        out_path.parent.mkdir(parents=True, exist_ok=True)
+        out_path.write_text(json_payload, encoding="utf-8")
+    return payload
+
+
+__all__ = [
+    "HinfResidualSensitivityError",
+    "build_hinf_residual_sensitivity",
+    "run_hinf_residual_sensitivity",
+]
