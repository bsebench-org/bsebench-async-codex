 @pytest.mark.fast
+def test_replay_writes_json_summary_on_success(
+    replay_module: ModuleType,
+    tmp_path: Path,
+    capsys: pytest.CaptureFixture[str],
+) -> None:
+    payload = _evidence_payload()
+    evidence_path = _write_evidence(tmp_path, payload)
+    summary_path = tmp_path / "summaries" / "replay-summary.json"
+
+    rc = replay_module.main(
+        ["--evidence", str(evidence_path), "--json-summary", str(summary_path)]
+    )
+
+    captured = capsys.readouterr()
+    assert rc == 0
+    assert "hinf residual stats replay ok" in captured.out
+    assert captured.err == ""
+
+    loaded = json.loads(summary_path.read_text(encoding="utf-8"))
+    json.dumps(loaded, allow_nan=False)
+    assert loaded["status"] == "ok"
+    assert loaded["replay_status"] == "ok"
+    assert loaded["evidence_path"] == str(evidence_path)
+    assert loaded["tolerances"] == {"atol": 1.0e-12, "rtol": 1.0e-12}
+    assert loaded["mismatch_count"] == 0
+    assert loaded["decomposition_shares"] == {
+        "config_share": payload["residual_variance_decomposition"]["decomposition"][
