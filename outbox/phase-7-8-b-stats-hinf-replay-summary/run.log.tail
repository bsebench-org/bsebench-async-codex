+    }
+    assert loaded["loo_stability_summary"] == payload["residual_variance_decomposition"][
+        "loo_config_stability"
+    ]["summary"]
+    for section_name in replay_module.SECTIONS:
+        section = loaded["sections"][section_name]
+        assert section["status"] == "ok"
+        assert section["compared_values"] > 0
+        assert section["mismatch_count"] == 0
+        assert section["mismatches"] == []
+
+
