+import importlib.util
+import json
+import sys
+from pathlib import Path
+from typing import Any
+
+import pytest
+
+SCRIPT_PATH = (
+    Path(__file__).resolve().parents[1] / "scripts" / "audit_hinf_residual_manifest_drift.py"
+)
+REPO_ROOT = Path(__file__).resolve().parents[1]
+MANIFEST_PATH = REPO_ROOT / "outputs" / "hinf_residual_artifact_manifest.json"
+SUMMARY_PATH = REPO_ROOT / "outputs" / "hinf_candidate_report_summary.json"
+SIDECAR_PATH = REPO_ROOT / "outputs" / "hinf_residual_sensitivity_5x5.json"
+
+
+def _load_script_module():
+    spec = importlib.util.spec_from_file_location("audit_hinf_residual_manifest_drift", SCRIPT_PATH)
+    assert spec is not None
+    assert spec.loader is not None
+    module = importlib.util.module_from_spec(spec)
+    sys.modules[spec.name] = module
+    spec.loader.exec_module(module)
+    return module
+
+
+@pytest.fixture(scope="module")
+def audit_module():
+    return _load_script_module()
+
+
+def _load_json(path: Path) -> dict[str, Any]:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def _write_json(path: Path, payload: dict[str, Any], *, allow_nan: bool = False) -> Path:
+    path.write_text(
+        json.dumps(payload, allow_nan=allow_nan, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+    return path
+
+
+@pytest.mark.fast
+def test_script_import_is_side_effect_free(audit_module) -> None:
+    assert callable(audit_module.audit_manifest_drift)
+    assert callable(audit_module.main)
+
+
+@pytest.mark.fast
+def test_committed_hinf_manifest_drift_audit_reports_json(audit_module, capsys) -> None:
+    report = audit_module.audit_manifest_drift()
+
+    assert report["status"] == "ok"
+    assert report["falsification_gate"]["evidence_bundle_drifted"] is False
+    assert report["artifacts"]["strict"]["evidence"]["sha256"] == (
+        "35c255c696fd9b63552c2206d08009aea834c17f3f09e2bd49b7ac5666917f78"
+    )
+    assert report["source_commits"]["manifest"]["bsebench_stats"]["locked_git_sha"] == (
+        "d7e86b72398e6785238797fabbb5c788d2294215"
+    )
+    assert report["source_commits"]["sensitivity_sidecar"]["bsebench_stats"]["git_sha"] == (
+        "6a892ee56aba401537d658fbfafca7443b3e559f"
+    )
+    assert report["strict_config_identity"]["config_labels"] == [
+        "Yao BCDC T25",
+        "Yao US06 T25",
+        "Panasonic US06 T25",
+        "NASA B0005 T24",
+        "CALCE A123 DST T25",
+    ]
+    assert report["guardrails"]["manifest"]["status"] == "mechanical_evidence_only"
+    assert report["sidecar_hashes"]["stats_payload"]["status"] == (
+        "matches_embedded_stats_sensitivity"
+    )
+
+    rc = audit_module.main([])
+    captured = capsys.readouterr()
+    assert rc == 0
+    cli_report = json.loads(captured.out)
+    assert cli_report["status"] == "ok"
+    assert cli_report["artifacts"]["ci_summary"]["path"] == (
+        "outputs/hinf_candidate_report_summary.json"
+    )
+
+
+@pytest.mark.fast
+def test_manifest_drift_audit_rejects_hash_drift(audit_module, tmp_path: Path) -> None:
+    bad_manifest = copy.deepcopy(_load_json(MANIFEST_PATH))
+    bad_manifest["artifacts"]["evidence"]["sha256"] = "0" * 64
+    bad_manifest_path = _write_json(tmp_path / "bad_manifest.json", bad_manifest)
+
+    with pytest.raises(
+        audit_module.HinfResidualManifestDriftAuditError,
+        match=r"artifacts\.evidence\.sha256",
+    ):
+        audit_module.audit_manifest_drift(manifest_path=bad_manifest_path)
+
+
+@pytest.mark.fast
+def test_manifest_drift_audit_rejects_missing_required_artifact(
+    audit_module,
+    tmp_path: Path,
+) -> None:
+    bad_manifest = copy.deepcopy(_load_json(MANIFEST_PATH))
+    bad_manifest["artifacts"]["evidence"]["path"] = "outputs/missing_hinf_evidence.json"
+    bad_manifest_path = _write_json(tmp_path / "missing_artifact_manifest.json", bad_manifest)
+
+    with pytest.raises(
+        audit_module.HinfResidualManifestDriftAuditError,
+        match=r"missing_hinf_evidence\.json",
+    ):
+        audit_module.audit_manifest_drift(manifest_path=bad_manifest_path)
+
+
+@pytest.mark.fast
+def test_manifest_drift_audit_rejects_source_sha_mismatch(
+    audit_module,
+    tmp_path: Path,
+) -> None:
+    bad_sidecar = copy.deepcopy(_load_json(SIDECAR_PATH))
+    bad_sidecar["provenance"]["bsebench_stats"]["git_sha"] = "0" * 40
+    bad_sidecar_path = _write_json(tmp_path / "bad_sidecar.json", bad_sidecar)
+
+    with pytest.raises(
+        audit_module.HinfResidualManifestDriftAuditError,
+        match=r"bsebench_stats\.git_sha",
+    ):
+        audit_module.audit_manifest_drift(sidecar_path=bad_sidecar_path)
+
+
+@pytest.mark.fast
+def test_manifest_drift_audit_rejects_forbidden_guardrail_wording(
+    audit_module,
+    tmp_path: Path,
+) -> None:
+    bad_summary = copy.deepcopy(_load_json(SUMMARY_PATH))
+    bad_summary["guardrails"]["scientific_verdict"] = "verified SOTA"
+    bad_summary_path = _write_json(tmp_path / "bad_summary.json", bad_summary)
+
+    with pytest.raises(
+        audit_module.HinfResidualManifestDriftAuditError,
+        match=r"summary\.guardrails\.scientific_verdict|forbidden positive claim term",
+    ):
+        audit_module.audit_manifest_drift(candidate_summary_path=bad_summary_path)
+
+
+@pytest.mark.fast
+def test_manifest_drift_audit_rejects_non_finite_json(
+    audit_module,
+    tmp_path: Path,
+) -> None:
+    bad_summary = copy.deepcopy(_load_json(SUMMARY_PATH))
+    bad_summary["counts"]["n_configs"] = float("nan")
+    bad_summary_path = _write_json(tmp_path / "nonfinite_summary.json", bad_summary, allow_nan=True)
+
+    with pytest.raises(
+        audit_module.HinfResidualManifestDriftAuditError,
+        match=r"non-finite JSON token NaN",
+    ):
+        audit_module.audit_manifest_drift(candidate_summary_path=bad_summary_path)
+
+
+@pytest.mark.fast
+def test_manifest_drift_audit_rejects_sidecar_stats_payload_hash_drift(
