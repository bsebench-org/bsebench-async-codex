+            },
+        ),
+    ]
+
+    payload = json.loads(output_path.read_text(encoding="utf-8"))
+    assert payload["script"] == "scripts/hinf_residual_evidence_5x5.py"
+    assert payload["scientific_verdict"] == "none"
+    assert payload["claim_target"] == "new_hinf_candidate_not_claim_55"
+    assert payload["trace"]["summary"] == {
+        "ok_configs": 5,
+        "error_configs": 0,
+        "ok_filter_runs": 25,
+        "error_filter_runs": 0,
+    }
+    assert payload["trace"]["filter_labels"] == ["EnsembleMeta", "EKF", "UKFDef", "JUKFV6B", "Hinf"]
+    assert "residual_covariance_panel" in payload
+    assert "residual_variance_decomposition" in payload
+
+    for config_payload in payload["trace"]["configs"].values():
+        retained = config_payload["retained_samples"]
+        hinf = config_payload["filters"]["Hinf"]
+        assert hinf["status"] == "ok"
+        assert hinf["retained_samples"] == retained
+        assert len(hinf["residual_mV"]) == retained
+
+
+@pytest.mark.fast
+def test_missing_hinf_fails_before_output_writing(evidence_module, tmp_path: Path) -> None:
+    balanced = _run_synthetic_bundle(evidence_module, tmp_path)["trace"]
+    trace_payload = copy.deepcopy(balanced)
+    trace_payload["filter_labels"] = ["EnsembleMeta", "EKF", "UKFDef", "JUKFV6B", "Other"]
+    for config_payload in trace_payload["configs"].values():
+        filters = config_payload["filters"]
+        filters["Other"] = filters.pop("Hinf")
+
+    output_path = tmp_path / "missing_hinf.json"
+
+    def trace_runner(**kwargs: Any) -> dict[str, Any]:
+        del kwargs
+        return trace_payload
+
+    def should_not_call(*args: Any, **kwargs: Any) -> dict[str, object]:
+        raise AssertionError("stats builder should not be called")
+
+    with pytest.raises(
+        evidence_module.HinfResidualEvidenceRequirementError,
+        match="filter_labels must be exactly",
+    ):
+        evidence_module.run_hinf_residual_evidence_5x5(
+            output_path=output_path,
+            covariance_builder=should_not_call,
+            decomposition_builder=should_not_call,
+            trace_runner=trace_runner,
+        )
+
+    assert not output_path.exists()
+
+
