+    assert normalized["corrected_residuals"] == pytest.approx([1.0, 0.5, -1.75])
+    assert normalized["steps"][0] == {
+        "index": 0,
+        "residual": 2.0,
+        "bias_before": 0.0,
+        "bias_after": 1.0,
+        "corrected_residual": 1.0,
+        "reset_applied": False,
+    }
+    assert normalized["steps"][2]["bias_after"] == pytest.approx(-0.25)
+    assert normalized["summary"]["sample_count"] == 3
+    assert normalized["summary"]["reset_count"] == 0
+    assert normalized["execution_policy"]["estimator_execution_allowed"] is False
+    assert normalized["execution_policy"]["dataset_download_allowed"] is False
+    assert normalized["execution_policy"]["neural_training_allowed"] is False
+    assert normalized["execution_policy"]["empirical_advantage_claim_allowed"] is False
+    assert normalized["execution_policy"]["adaptive_gain_claim_allowed"] is False
+    assert_phase15_ema_bias_correction_report(report)
+    json.dumps(normalized, allow_nan=False)
+
+
+def test_reset_before_indices_restart_bias_state() -> None:
+    report = _valid_report(residuals=[4.0, 4.0, 4.0], reset_before_indices=(2,))
+
+    assert report["reset_before_indices"] == [2]
+    assert report["corrected_residuals"] == pytest.approx([2.0, 1.0, 2.0])
+    assert report["steps"][1]["bias_before"] == pytest.approx(2.0)
+    assert report["steps"][2]["bias_before"] == pytest.approx(0.0)
+    assert report["steps"][2]["reset_applied"] is True
+    assert report["summary"]["reset_count"] == 1
+    assert report["summary"]["final_bias"] == pytest.approx(2.0)
+
+
+def test_stateful_corrector_reset_keeps_sample_index_and_resets_bias_only() -> None:
+    corrector = EMAResidualBiasCorrector(alpha=0.25, initial_bias=1.0)
+
+    first = corrector.update(5.0)
+    corrector.reset()
+    second = corrector.update(5.0)
+
+    assert first.index == 0
+    assert first.bias_before == pytest.approx(1.0)
+    assert first.bias_after == pytest.approx(2.0)
+    assert second.index == 1
+    assert second.bias_before == pytest.approx(1.0)
+    assert corrector.sample_count == 2
+    assert corrector.reset_count == 1
+
+
+@pytest.mark.parametrize("alpha", [0.0, -0.1, 1.01, float("nan"), True])
+def test_alpha_bounds_fail_closed(alpha: object) -> None:
+    with pytest.raises(
+        Phase15EMABiasCorrectionValidationError,
+        match="alpha must",
+    ):
+        _valid_report(alpha=alpha)
+
+
+def test_nonfinite_residuals_are_rejected_without_advancing_state() -> None:
+    corrector = EMAResidualBiasCorrector(alpha=0.5)
+    first = corrector.update(2.0)
+
+    with pytest.raises(Phase15EMABiasCorrectionValidationError, match="residual must be finite"):
+        corrector.update(float("nan"))
+
+    assert first.bias_after == pytest.approx(1.0)
+    assert corrector.bias == pytest.approx(1.0)
+    assert corrector.sample_count == 1
+
+    with pytest.raises(
+        Phase15EMABiasCorrectionValidationError,
+        match=r"residuals\[1\] must be finite",
+    ):
+        _valid_report(residuals=[1.0, float("inf")])
+
+
+@pytest.mark.parametrize(
+    ("mutation", "message"),
+    [
+        (
+            lambda evidence: evidence.pop("split_manifest_sha256"),
+            r"evidence\.split_manifest_sha256 must be a sha256 hex digest",
+        ),
+        (
+            lambda evidence: evidence.update({"provenance_sha256": "not-a-sha"}),
+            r"evidence\.provenance_sha256 must be a sha256 hex digest",
+        ),
+    ],
+)
+def test_missing_or_invalid_synthetic_evidence_fails_closed(mutation, message: str) -> None:
+    evidence = _evidence()
+    mutation(evidence)
+
+    with pytest.raises(Phase15EMABiasCorrectionValidationError, match=message):
+        _valid_report(evidence=evidence)
+
+
+def test_split_reuse_is_rejected_as_leakage() -> None:
+    with pytest.raises(
+        Phase15EMABiasCorrectionValidationError,
+        match="calibration_split_id and correction_split_id must be distinct",
+    ):
+        _valid_report(
+            calibration_split_id="synthetic_same_split",
+            correction_split_id="synthetic_same_split",
+        )
+
+
+@pytest.mark.parametrize(
+    ("overrides", "message"),
+    [
+        ({"claim_status": "RMSE_GAIN"}, "claim_status must remain NO_GO_CLAIM"),
+        (
+            {"notes": "synthetic adaptive gain calibration"},
+            "forbidden adaptive-gain wording",
+        ),
+        (
+            {"stream_id": "phase15_sota_residual_helper"},
+            "unsupported claim wording: sota",
+        ),
+    ],
+)
+def test_unsupported_claim_and_adaptive_gain_wording_fails_closed(
+    overrides: dict[str, object],
+    message: str,
+) -> None:
+    with pytest.raises(Phase15EMABiasCorrectionValidationError, match=message):
+        _valid_report(**overrides)
+
+
+def test_report_validator_recomputes_steps_and_returns_blocking_gaps() -> None:
+    report = deepcopy(_valid_report())
+    report["steps"][1]["bias_after"] = 1.0
+
+    with pytest.raises(
+        Phase15EMABiasCorrectionValidationError,
+        match=r"steps\[1\]\.bias_after does not match EMA update",
+    ):
+        validate_phase15_ema_bias_correction_report(report)
+    assert ema_bias_correction_blocking_gaps(report) == (
+        "steps[1].bias_after does not match EMA update",
+    )

