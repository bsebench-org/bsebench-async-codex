for check in checks:
    print(f\"{check['label']}:\")
    print(f\"  wrapper: {check['wrapper']}\")
    print(f\"  loader_class: {check['class'].__module__}.{check['class'].__name__}\")
    print(f\"  hf_repo: {check['repo']}\")
    print(f\"  local_cache_root: {check['root']} ({'exists' if check['root'].is_dir() else 'missing'})\")
    print(\"  expected_files:\")
    for name in check[\"expected_files\"]:
        p = check[\"root\"] / name
        print(f\"    {name}: {'present' if p.is_file() else 'missing'}\")
    try:
        loader = make_loader(check[\"class\"], check[\"root\"])
        configs = loader.available_configs()
        targets = check[\"targets\"]
        hit_flags = [target in configs for target in targets]
        print(\"  available_configs_no_network: success\")
        print(f\"  available_configs: {summarize_configs(configs)}\")
        print(\"  target_configs_present: \" + \", \".join(f\"{target}={'yes' if hit else 'no'}\" for target, hit in zip(targets, hit_flags)))
    except Exception as exc:
        print(\"  available_configs_no_network: failure\")
        print(f\"  exception: {exc.__class__.__name__}: {str(exc).splitlines()[0][:240]}\")
