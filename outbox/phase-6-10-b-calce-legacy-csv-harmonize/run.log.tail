 )
 
 
+def _write_legacy_csv(
+    root: Path,
+    filename: str = "A123_25C.csv",
+    *,
+    rows: list[tuple[float, float, float, float, int]],
+) -> Path:
+    csv_path = root / filename
+    lines = ["time_s,current_A,voltage_V,temperature_C,step_index"]
+    lines.extend(
+        f"{time_s},{current_a},{voltage_v},{temperature_c},{step_index}"
+        for time_s, current_a, voltage_v, temperature_c, step_index in rows
+    )
+    csv_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return csv_path
+
+
+def _read_table(path: Path):
+    return pq.read_table(str(path))
+
