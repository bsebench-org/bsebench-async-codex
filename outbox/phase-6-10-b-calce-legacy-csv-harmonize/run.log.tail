+def test_harmonize_writes_parquet_for_existing_csv(tmp_path: Path) -> None:
+    rows = []
+    for idx in range(20):
+        if idx < 7:
+            step_index = idx + 1
+        else:
+            step_index = 8 + ((idx - 7) % 5)
+        rows.append((10.0 + idx * 0.5, -1.0, 3.3 - idx * 0.01, 25.0, step_index))
+    _write_legacy_csv(tmp_path, rows=rows)
+
+    out_dir = tmp_path / "out"
+    written = CalceA123Adapter(local_root=tmp_path).harmonize(output_dir=out_dir)
+
+    expected_path = out_dir / "calce_a123_DST_T25.parquet"
+    assert written == {"A123_T25": expected_path}
+    assert expected_path.is_file()
+
+    table = _read_table(expected_path)
+    assert table.num_rows == 13
+    assert table.column_names == ["time_s", "voltage_V", "current_A", "temperature_C"]
+    assert table.column("time_s").to_pylist()[0] == pytest.approx(0.0)
+
+
