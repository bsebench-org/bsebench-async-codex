+            tc_dst = tc_arr[mask]
+
+            # Write Parquet via pyarrow (mirror Yao adapter style).
+            table = pa.table(
+                {
+                    "time_s": t_dst,
+                    "voltage_V": v_dst,
+                    "current_A": i_dst,
+                    "temperature_C": tc_dst,
+                }
+            )
+            cell_id = f"A123_T{temp_c}"
+            out_path = output_dir / f"calce_a123_DST_T{temp_c}.parquet"
+            pq.write_table(table, out_path)
+            written[cell_id] = out_path
+
+        return written
