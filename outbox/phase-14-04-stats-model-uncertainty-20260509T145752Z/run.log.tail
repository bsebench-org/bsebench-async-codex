+    assert report["decision"]["validated_mixture_information_blocks_supplied"] is True
+    assert (
+        report["decision"][
+            "true_bayesian_model_uncertainty_pcrlb_label_allowed_by_input_contract"
+        ]
+        is True
+    )
+    assert report["blocking_gaps"] == []
+
+    summary = report["weighted_conditional_summary"]
+    assert summary["status"] == "available"
+    assert summary["is_true_bayesian_model_uncertainty_pcrlb"] is False
+    assert summary["weights"] == {"model-a": pytest.approx(0.4), "model-b": pytest.approx(0.6)}
+    assert summary["information_matrices"][0] == [
+        [pytest.approx(5.2), pytest.approx(0.0)],
+        [pytest.approx(0.0), pytest.approx(10.8)],
+    ]
+    assert summary["information_matrices"][1] == [
+        [pytest.approx(6.8), pytest.approx(0.0)],
+        [pytest.approx(0.0), pytest.approx(13.6)],
+    ]
+    _assert_strict_json(report)
+
+
+@pytest.mark.fast
