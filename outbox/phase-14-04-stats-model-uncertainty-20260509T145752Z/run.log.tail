+        report["decision"][
+            "true_bayesian_model_uncertainty_pcrlb_label_allowed_by_input_contract"
+        ]
+        is False
+    )
+    assert report["weighted_conditional_summary"]["status"] == "available"
+    assert (
+        report["weighted_conditional_summary"]["is_true_bayesian_model_uncertainty_pcrlb"]
+        is False
+    )
+    assert report["blocking_gaps"] == []
+    _assert_strict_json(report)
