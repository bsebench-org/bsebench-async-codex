+    )
+
+    assert report["decision"]["preflight_status"] == "ready"
+    assert report["scientific_verdict"] == NO_GO_CLAIM
+    assert report["component_status"]["mixture_information_blocks"]["status"] == "not_supplied"
+    assert report["decision"]["validated_mixture_information_blocks_supplied"] is False
